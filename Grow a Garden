local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local VirtualInputManager = game:GetService("VirtualInputManager")
local TweenService = game:GetService("TweenService")

-- Place 1: Booth place
if game.PlaceId == 129954712878723 then
    -- Anti-AFK (no jump)
    task.spawn(function()
        while true do
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F15, false, game)
            task.wait(0.05)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F15, false, game)
            task.wait(math.random(2,5))
        end
    end)

    -- Booth claiming logic
    local function claimClosestBooth()
        local TradeWorld = Workspace:WaitForChild("TradeWorld")
        local Booths = TradeWorld:WaitForChild("Booths")
        local Sign = TradeWorld:WaitForChild("ArtisanContainerSign")
        local ClaimEvent = ReplicatedStorage:WaitForChild("GameEvents")
            :WaitForChild("TradeEvents")
            :WaitForChild("Booths")
            :WaitForChild("ClaimBooth")

        -- Find closest empty booth
        local closestBooth = nil
        local shortestDistance = math.huge
        local signPos = Sign:GetPivot().Position

        for _, booth in ipairs(Booths:GetChildren()) do
            if booth:IsA("Model") then
                local dynamic = booth:FindFirstChild("DynamicInstances")
                if dynamic and #dynamic:GetChildren() == 0 then
                    local boothPos
                    pcall(function()
                        boothPos = booth:GetPivot().Position
                    end)
                    if boothPos then
                        local distance = (boothPos - signPos).Magnitude
                        if distance < shortestDistance then
                            shortestDistance = distance
                            closestBooth = booth
                        end
                    end
                end
            end
        end

        if closestBooth then
            print("Claiming booth:", closestBooth.Name)
            ClaimEvent:FireServer(closestBooth.Name) -- use Name instead of model
        else
            print("No empty booths near the sign.")
        end
    end

    -- Optional: you can auto-claim or show Yes/No popup
    task.wait(1)
    claimClosestBooth()
end

