local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local VirtualInputManager = game:GetService("VirtualInputManager")
local TweenService = game:GetService("TweenService")

if game.PlaceId == 129954712878723 then
    -- Anti-AFK (no jump)
    task.spawn(function()
        while true do
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F15, false, game)
            task.wait(0.05)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F15, false, game)
            task.wait(math.random(2,5))
        end
    end)

    -- Wait until TradeWorld is fully loaded
    local TradeWorld = Workspace:WaitForChild("TradeWorld")
    local Booths = TradeWorld:WaitForChild("Booths")
    local Sign = TradeWorld:WaitForChild("ArtisanContainerSign")
    local ClaimEvent = ReplicatedStorage:WaitForChild("GameEvents")
        :WaitForChild("TradeEvents")
        :WaitForChild("Booths")
        :WaitForChild("ClaimBooth")

    local signPos = Sign:GetPivot().Position

    -- Function to get all empty booths
    local function getEmptyBooths()
        local emptyBooths = {}
        for _, booth in ipairs(Booths:GetChildren()) do
            if booth:IsA("Model") then
                local dynamic = booth:FindFirstChild("DynamicInstances")
                if dynamic and #dynamic:GetChildren() == 0 then
                    table.insert(emptyBooths, booth)
                end
            end
        end
        return emptyBooths
    end

    -- Function to find the closest empty booth
    local function getClosestEmptyBooth()
        local emptyBooths = getEmptyBooths()
        local closestBooth = nil
        local shortestDistance = math.huge

        for _, booth in ipairs(emptyBooths) do
            local boothPos
            pcall(function()
                boothPos = booth:GetPivot().Position
            end)
            if boothPos then
                local distance = (boothPos - signPos).Magnitude
                if distance < shortestDistance then
                    shortestDistance = distance
                    closestBooth = booth
                end
            end
        end

        -- If no “closest” found (all far or emptyBooths empty), pick random empty booth
        if not closestBooth and #emptyBooths > 0 then
            closestBooth = emptyBooths[math.random(1, #emptyBooths)]
        end

        return closestBooth
    end

    -- Main loop: keep checking until an empty booth is found
    task.spawn(function()
        while true do
            local boothToClaim = getClosestEmptyBooth()
            if boothToClaim then
                print("Found booth to claim:", boothToClaim.Name)

                -- Optional: show confirmation GUI before claiming
                local CoreGui = game:GetService("CoreGui")
                local screenGui = Instance.new("ScreenGui", CoreGui)
                screenGui.ResetOnSpawn = false

                local frame = Instance.new("Frame", screenGui)
                frame.Size = UDim2.new(0, 300, 0, 100)
                frame.Position = UDim2.new(1, -310, 1, -110)
                frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
                frame.BorderSizePixel = 0
                frame.AnchorPoint = Vector2.new(0,0)
                frame.ClipsDescendants = true
                frame.Rotation = 10
                local corner = Instance.new("UICorner", frame)
                corner.CornerRadius = UDim.new(0,12)

                local title = Instance.new("TextLabel", frame)
                title.Size = UDim2.new(1,-20,0,30)
                title.Position = UDim2.new(0,10,0,10)
                title.BackgroundTransparency = 1
                title.Text = "Booth Found!"
                title.TextColor3 = Color3.fromRGB(255,255,255)
                title.Font = Enum.Font.GothamBold
                title.TextScaled = true
                title.TextXAlignment = Enum.TextXAlignment.Left

                local msg = Instance.new("TextLabel", frame)
                msg.Size = UDim2.new(1,-20,0,40)
                msg.Position = UDim2.new(0,10,0,40)
                msg.BackgroundTransparency = 1
                msg.Text = "Do you want to claim this booth?"
                msg.TextColor3 = Color3.fromRGB(200,200,200)
                msg.Font = Enum.Font.Gotham
                msg.TextScaled = true
                msg.TextWrapped = true
                msg.TextXAlignment = Enum.TextXAlignment.Left

                local yesBtn = Instance.new("TextButton", frame)
                yesBtn.Size = UDim2.new(0.45,0,0.25,0)
                yesBtn.Position = UDim2.new(0.05,0,0.7,0)
                yesBtn.Text = "YES"
                yesBtn.BackgroundColor3 = Color3.fromRGB(0,170,0)
                yesBtn.TextColor3 = Color3.fromRGB(255,255,255)
                yesBtn.Font = Enum.Font.GothamBold
                yesBtn.TextScaled = true
                local yesCorner = Instance.new("UICorner", yesBtn)
                yesCorner.CornerRadius = UDim.new(0,8)

                local noBtn = Instance.new("TextButton", frame)
                noBtn.Size = UDim2.new(0.45,0,0.25,0)
                noBtn.Position = UDim2.new(0.5,0,0.7,0)
                noBtn.Text = "NO"
                noBtn.BackgroundColor3 = Color3.fromRGB(170,0,0)
                noBtn.TextColor3 = Color3.fromRGB(255,255,255)
                noBtn.Font = Enum.Font.GothamBold
                noBtn.TextScaled = true
                local noCorner = Instance.new("UICorner", noBtn)
                noCorner.CornerRadius = UDim.new(0,8)

                -- Slide-in animation
                local tweenInfo = TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
                TweenService:Create(frame, tweenInfo, {Position = UDim2.new(1,-310,1,-120), Rotation = 0}):Play()

                yesBtn.MouseButton1Click:Connect(function()
                    ClaimEvent:FireServer(boothToClaim.Name)
                    TweenService:Create(frame, TweenInfo.new(0.3), {Position = UDim2.new(1,310,1,-120), Rotation = 10}):Play()
                    task.delay(0.35,function() screenGui:Destroy() end)
                    print("Claimed booth:", boothToClaim.Name)
                end)

                noBtn.MouseButton1Click:Connect(function()
                    TweenService:Create(frame, TweenInfo.new(0.3), {Position = UDim2.new(1,310,1,-120), Rotation = 10}):Play()
                    task.delay(0.35,function() screenGui:Destroy() end)
                    print("User declined booth claim.")
                end)

                break -- exit loop once notification is shown, wait for user
            else
                -- no empty booths, wait 2 seconds and check again
                task.wait(2)
            end
        end
    end)
end
