task.spawn(function()
    while true do
        vim:SendKeyEvent(true, Enum.KeyCode.F15, false, game)
        task.wait(0.05)
        vim:SendKeyEvent(false, Enum.KeyCode.F15, false, game)

        task.wait(math.random(2,5))
