local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local VirtualInputManager = game:GetService("VirtualInputManager")
local TweenService = game:GetService("TweenService")

--------------------------------------------------
-- PLACE 1: BOOTH AUTO CLAIM
--------------------------------------------------
if game.PlaceId == 129954712878723 then

    -- Anti-AFK (no jump)
    task.spawn(function()
        while true do
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F15, false, game)
            task.wait(0.05)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F15, false, game)
            task.wait(math.random(2,5))
        end
    end)

    -- Wait for world
    local TradeWorld = Workspace:WaitForChild("TradeWorld")
    local Booths = TradeWorld:WaitForChild("Booths")
    local Sign = TradeWorld:WaitForChild("ArtisanContainerSign")

    local ClaimEvent = ReplicatedStorage:WaitForChild("GameEvents")
        :WaitForChild("TradeEvents")
        :WaitForChild("Booths")
        :WaitForChild("ClaimBooth")

    -- Get position safely
    local function getPos(model)
        local ok, result = pcall(function()
            return model:GetPivot().Position
        end)
        return ok and result or nil
    end

    -- Find best booth (closest → fallback random)
    local function findBooth()
        local empty = {}
        local closest = nil
        local shortest = math.huge

        local signPos = getPos(Sign)
        if not signPos then return nil end

        for _, booth in ipairs(Booths:GetChildren()) do
            if booth:IsA("Model") then
                local dynamic = booth:FindFirstChild("DynamicInstances")

                if dynamic and #dynamic:GetChildren() == 0 then
                    table.insert(empty, booth)

                    local pos = getPos(booth)
                    if pos then
                        local dist = (pos - signPos).Magnitude
                        if dist < shortest then
                            shortest = dist
                            closest = booth
                        end
                    end
                end
            end
        end

        -- priority: closest → else random
        if closest then
            return closest
        elseif #empty > 0 then
            return empty[math.random(1, #empty)]
        end

        return nil
    end

    -- Main loop (keeps trying until success)
    task.spawn(function()
        task.wait(2) -- allow full load

        while true do
            local booth = findBooth()

            if booth then
                print("Trying to claim:", booth.Name)

                ClaimEvent:FireServer(booth) -- ✅ correct

                task.wait(2)

                -- check if claimed
                local dynamic = booth:FindFirstChild("DynamicInstances")
                if dynamic and #dynamic:GetChildren() > 0 then
                    print("✅ Successfully claimed:", booth.Name)
                    break
                else
                    print("❌ Claim failed, retrying...")
                end
            else
                print("⏳ No empty booths, waiting...")
            end

            task.wait(2)
        end
    end)
end

