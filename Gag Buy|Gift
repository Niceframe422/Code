local function getInitials(name)
	local parts = string.gmatch(name, "%u")
	local a, b = parts(), parts()
	if a and b then
		return a .. b
	elseif a then
		return a .. (string.sub(name, 2, 2):upper())
	end
	return string.sub(name, 1, 2):upper()
end

local function selectPlayer(plr, btn)
	if SelectedButton then
		tween(SelectedButton, FAST, {
			BackgroundColor3 = Color3.fromRGB(28, 28, 28),
			BackgroundTransparency = 0,
		})
		local lbl = SelectedButton:FindFirstChild("NameLabel")
		if lbl then
			tween(lbl, FAST, { TextColor3 = Color3.fromRGB(180, 180, 180) })
		end
	end
	SelectedPlayer = plr
	SelectedButton = btn
	tween(btn, FAST, { BackgroundColor3 = Color3.fromRGB(40, 70, 140) })
	local lbl = btn:FindFirstChild("NameLabel")
	if lbl then
		tween(lbl, FAST, { TextColor3 = Color3.fromRGB(150, 190, 255) })
	end
end

