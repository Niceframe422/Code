local ActiveFilter = "All"
local FilterButtons = {}
local ProductCards  = {}   -- { card, category } pairs for filtering

local function applyFilter(cat)
	ActiveFilter = cat

	-- Update filter button visuals
	for _, fb in pairs(FilterButtons) do
		local isActive = (fb.Category == cat)
		local col = isActive and categoryColor(fb.Category ~= "All" and fb.Category or "Seeds")
			or Color3.fromRGB(60, 60, 60)
		tween(fb.Button, FAST, { BackgroundColor3 = col })
		fb.Button.TextColor3 = isActive
			and Color3.fromRGB(240, 240, 240)
			or Color3.fromRGB(140, 140, 140)
	end

	-- Show/hide product cards
	for _, entry in pairs(ProductCards) do
		local visible = (cat == "All") or (entry.Category == cat)
		entry.Card.Visible = visible
	end
end

