-- Returns a buy button that spans full width when alone, or half-width at xOff
local function makeButton(parent, text, xOff, width, color)
	local btn = Instance.new("TextButton", parent)
	btn.Size             = UDim2.new(width, -4, 0, 28)
	btn.Position         = UDim2.new(xOff, 4, 1, -34)
	btn.BackgroundColor3 = color
	btn.Text             = text
	btn.TextColor3       = Color3.fromRGB(220, 220, 220)
	btn.Font             = Enum.Font.GothamBold
	btn.TextSize         = 12
	btn.AutoButtonColor  = false
	btn.BorderSizePixel  = 0
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
	return btn
end

local function setButtonLoading(btn, loading, originalText)
	btn.Active                 = not loading
	btn.Text                   = loading and "..." or originalText
	btn.BackgroundTransparency = loading and 0.5 or 0
end

local function createProductCard(data)
	local accentColor = categoryColor(data.Category)
	local giftable    = data.isGiftable == true  -- explicit opt-in

	local card = Instance.new("Frame", ProductScroll)
	card.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
	card.BorderSizePixel  = 0
	Instance.new("UICorner", card).CornerRadius = UDim.new(0, 10)

	local stroke = Instance.new("UIStroke", card)
	stroke.Color        = Color3.fromRGB(255, 255, 255)
	stroke.Transparency = 0.88
	stroke.Thickness    = 0.5

	card.MouseEnter:Connect(function()
		tween(stroke, FAST, { Color = accentColor, Transparency = 0.45 })
	end)
	card.MouseLeave:Connect(function()
		tween(stroke, FAST, { Color = Color3.fromRGB(255, 255, 255), Transparency = 0.88 })
	end)

	-- Category badge
	local badge = Instance.new("TextLabel", card)
	badge.Size                   = UDim2.new(0, 0, 0, 18)
	badge.AutomaticSize          = Enum.AutomaticSize.X
	badge.Position               = UDim2.new(0, 10, 0, 10)
	badge.BackgroundColor3       = accentColor
	badge.BackgroundTransparency = 0.75
	badge.Text                   = data.Category
	badge.TextColor3             = accentColor
	badge.Font                   = Enum.Font.GothamBold
	badge.TextSize               = 10
	badge.BorderSizePixel        = 0
	Instance.new("UICorner", badge).CornerRadius = UDim.new(1, 0)
	local badgePad = Instance.new("UIPadding", badge)
	badgePad.PaddingLeft  = UDim.new(0, 8)
	badgePad.PaddingRight = UDim.new(0, 8)

	-- Product name
	local title = Instance.new("TextLabel", card)
	title.Size                   = UDim2.new(1, -20, 0, 44)
	title.Position               = UDim2.new(0, 10, 0, 32)
	title.BackgroundTransparency = 1
	title.Text                   = data.Display
	title.TextColor3             = Color3.fromRGB(210, 210, 210)
	title.Font                   = Enum.Font.GothamBold
	title.TextSize               = 14
	title.TextXAlignment         = Enum.TextXAlignment.Left
	title.TextYAlignment         = Enum.TextYAlignment.Top
	title.TextWrapped            = true

	-- Price label (Robux icon approximated with "R$" text)
	local priceLabel = Instance.new("TextLabel", card)
	priceLabel.Size                   = UDim2.new(1, -20, 0, 18)
	priceLabel.Position               = UDim2.new(0, 10, 0, 78)
	priceLabel.BackgroundTransparency = 1
	priceLabel.Text                   = data.Price and formatPrice(data.Price) or "Free"
	priceLabel.TextColor3             = Color3.fromRGB(100, 200, 100)   -- green for Robux feel
	priceLabel.Font                   = Enum.Font.GothamBold
	priceLabel.TextSize               = 13
	priceLabel.TextXAlignment         = Enum.TextXAlignment.Left

	-- Buttons: layout depends on whether this item is giftable
	-- • Giftable  → Buy (48%) | Gift (48%) — gift hidden when self selected
	-- • Not giftable → Buy (full width)
	local buyBtn, giftBtn

	if giftable then
		buyBtn  = makeButton(card, "Buy",    0,    0.5, Color3.fromRGB(30,  60, 130))
		giftBtn = makeButton(card, "Gift →", 0.5,  0.5, Color3.fromRGB(100, 35,  80))

		-- Immediately set correct visibility based on current selection
		giftBtn.Visible = (SelectedPlayer ~= LocalPlayer)

		-- Re-evaluate whenever the selected player changes
		table.insert(onPlayerChangedCallbacks, function(newPlayer)
			if not card.Parent then return end  -- card was destroyed
			local isSelf = (newPlayer == LocalPlayer)
			giftBtn.Visible = not isSelf
			-- Expand Buy to full width when Gift is hidden
			buyBtn.Size     = UDim2.new(isSelf and 0.97 or 0.5, -4, 0, 28)
		end)
	else
		-- Non-giftable: single full-width Buy button
		buyBtn = makeButton(card, "Buy", 0, 0.97, Color3.fromRGB(30, 60, 130))
	end

	-- BUY handler
	buyBtn.MouseButton1Click:Connect(function()
		if not data.NormalId then
			showToast("This item has no purchasable ID.", Color3.fromRGB(200, 80, 80))
			return
		end
		setButtonLoading(buyBtn, true, "Buy")
		task.spawn(function()
			local ok, err = pcall(function()
				PurchaseRemote:InvokeServer(data.NormalId)
			end)
			setButtonLoading(buyBtn, false, "Buy")
			if ok then
				showToast("Purchased " .. data.Display, categoryColor(data.Category))
			else
				showToast("Purchase failed: " .. tostring(err), Color3.fromRGB(200, 80, 80))
			end
		end)
	end)

	-- GIFT handler (only wired when giftable)
	if giftable and giftBtn then
		giftBtn.MouseButton1Click:Connect(function()
			-- Extra runtime guard: never gift to self even if button is visible
			if SelectedPlayer == LocalPlayer then
				showToast("You can't gift to yourself.", Color3.fromRGB(200, 80, 80))
				return
			end
			local target = Players:GetPlayerByUserId(SelectedPlayer.UserId)
			if not target then
				showToast("That player has left the game.", Color3.fromRGB(200, 80, 80))
				return
			end
			if not data.NormalId then
				showToast("This item cannot be gifted.", Color3.fromRGB(200, 80, 80))
				return
			end
			setButtonLoading(giftBtn, true, "Gift →")
			task.spawn(function()
				local ok, err = pcall(function()
					GiftRemote:FireServer({
						productId    = data.NormalId,
						targetUserId = target.UserId,
					})
				end)
				setButtonLoading(giftBtn, false, "Gift →")
				if ok then
					showToast("Gifted " .. data.Display .. " to " .. target.Name, categoryColor(data.Category))
				else
					showToast("Gift failed: " .. tostring(err), Color3.fromRGB(200, 80, 80))
				end
			end)
		end)
	end

	table.insert(ProductCards, { Card = card, Category = data.Category })
end

for _, data in pairs(Products) do
	createProductCard(data)
end

