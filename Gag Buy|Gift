-- PLAYER SELECTION
-- When a player is selected, we broadcast to all cards so they can
-- show or hide their Gift button accordingly.
------------------------------------------------
local SelectedPlayer = LocalPlayer
local SelectedButton = nil

-- Callbacks registered by each card to react to player selection changes
local onPlayerChangedCallbacks = {}

local function notifyPlayerChanged(newPlayer)
	for _, cb in ipairs(onPlayerChangedCallbacks) do
		cb(newPlayer)
	end
end

local function getInitials(name)
	local up = string.gmatch(name, "%u")
	local a, b = up(), up()
	if a and b then return a .. b
	elseif a     then return a .. string.sub(name, 2, 2):upper()
	end
	return string.sub(name, 1, 2):upper()
end

local function selectPlayer(plr, btn)
	if SelectedButton then
		tween(SelectedButton, FAST, { BackgroundColor3 = Color3.fromRGB(28, 28, 28) })
		local lbl = SelectedButton:FindFirstChild("NameLabel")
		if lbl then tween(lbl, FAST, { TextColor3 = Color3.fromRGB(180, 180, 180) }) end
	end
	SelectedPlayer = plr
	SelectedButton = btn
	tween(btn, FAST, { BackgroundColor3 = Color3.fromRGB(40, 70, 140) })
	local lbl = btn:FindFirstChild("NameLabel")
	if lbl then tween(lbl, FAST, { TextColor3 = Color3.fromRGB(150, 190, 255) }) end

	-- Tell every card about the new selection
	notifyPlayerChanged(plr)
end

local function createPlayerButton(plr)
	local btn = Instance.new("TextButton", PlayerScroll)
	btn.Name                   = "PlayerBtn_" .. plr.Name
	btn.Size                   = UDim2.new(1, 0, 0, 54)
	btn.BackgroundColor3       = Color3.fromRGB(28, 28, 28)
	btn.BackgroundTransparency = 0
	btn.Text                   = ""
	btn.AutoButtonColor        = false
	btn.BorderSizePixel        = 0
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

	-- Avatar frame (circle)
	local avFrame = Instance.new("Frame", btn)
	avFrame.Name             = "Avatar"
	avFrame.Size             = UDim2.new(0, 34, 0, 34)
	avFrame.Position         = UDim2.new(0, 10, 0.5, -17)
	avFrame.BackgroundColor3 = Color3.fromRGB(30, 35, 55)
	avFrame.BorderSizePixel  = 0
	Instance.new("UICorner", avFrame).CornerRadius = UDim.new(1, 0)

	local initLabel = Instance.new("TextLabel", avFrame)
	initLabel.Size                  = UDim2.fromScale(1, 1)
	initLabel.BackgroundTransparency = 1
	initLabel.Text                  = getInitials(plr.Name)
	initLabel.TextColor3            = Color3.fromRGB(150, 190, 255)
