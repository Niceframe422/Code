	avImg.ImageTransparency      = 1
	avImg.ScaleType              = Enum.ScaleType.Crop
	Instance.new("UICorner", avImg).CornerRadius = UDim.new(1, 0)

	task.spawn(function()
		local ok, url = pcall(function()
			return Players:GetUserThumbnailAsync(
				plr.UserId,
				Enum.ThumbnailType.HeadShot,
				Enum.ThumbnailSize.Size48x48
			)
		end)
		if ok and url and url ~= "" then
			avImg.Image            = url
			avImg.ImageTransparency = 0
			initLabel.Visible      = false
		end
	end)

	local nameLabel = Instance.new("TextLabel", btn)
	nameLabel.Name             = "NameLabel"
	nameLabel.Size             = UDim2.new(1, -54, 0, 20)
	nameLabel.Position         = UDim2.new(0, 52, 0, 8)
	nameLabel.BackgroundTransparency = 1
