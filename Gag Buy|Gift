GridPad.PaddingLeft   = UDim.new(0, 12)
GridPad.PaddingRight  = UDim.new(0, 12)

------------------------------------------------
-- FILTER STATE
------------------------------------------------
local ActiveFilter = "All"
local FilterButtons = {}
local ProductCards  = {}

local function applyFilter(cat)
	ActiveFilter = cat
	for _, fb in pairs(FilterButtons) do
		local isActive = (fb.Category == cat)
		local col = isActive
			and (cat ~= "All" and categoryColor(cat) or Color3.fromRGB(100, 100, 115))
			or Color3.fromRGB(38, 38, 38)
		tween(fb.Button, FAST, { BackgroundColor3 = col })
		fb.Button.TextColor3 = isActive
			and Color3.fromRGB(240, 240, 240)
			or Color3.fromRGB(130, 130, 130)
	end
	for _, entry in pairs(ProductCards) do
		entry.Card.Visible = (cat == "All") or (entry.Category == cat)
	end
end

------------------------------------------------
-- FILTER BUTTONS
------------------------------------------------
for i, cat in ipairs(Categories) do
	local fb = Instance.new("TextButton", FilterScroll)
	fb.LayoutOrder     = i
	fb.AutoButtonColor = false
	fb.BackgroundColor3 = (cat == "All")
		and Color3.fromRGB(80, 80, 90)
		or Color3.fromRGB(38, 38, 38)
	fb.TextColor3      = (cat == "All")
		and Color3.fromRGB(240, 240, 240)
		or Color3.fromRGB(130, 130, 130)
	fb.Font            = Enum.Font.Gotham
	fb.TextSize        = 12
	fb.Text            = cat
	fb.Size            = UDim2.new(0, 0, 0, 30)
	fb.AutomaticSize   = Enum.AutomaticSize.X
	fb.BorderSizePixel = 0
	Instance.new("UICorner", fb).CornerRadius = UDim.new(1, 0)

	local fbPad = Instance.new("UIPadding", fb)
	fbPad.PaddingLeft  = UDim.new(0, 14)
	fbPad.PaddingRight = UDim.new(0, 14)

	fb.MouseEnter:Connect(function()
		if ActiveFilter ~= cat then
			tween(fb, FAST, { BackgroundColor3 = Color3.fromRGB(52, 52, 58) })
		end
	end)
	fb.MouseLeave:Connect(function()
		if ActiveFilter ~= cat then
			tween(fb, FAST, { BackgroundColor3 = Color3.fromRGB(38, 38, 38) })
		end
	end)
	fb.MouseButton1Click:Connect(function()
		applyFilter(cat)
	end)

	table.insert(FilterButtons, { Button = fb, Category = cat })
end

