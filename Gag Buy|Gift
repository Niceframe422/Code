		youLabel.Size             = UDim2.new(1, -54, 0, 14)
		youLabel.Position         = UDim2.new(0, 52, 0, 30)
		youLabel.BackgroundTransparency = 1
		youLabel.Text             = "you"
		youLabel.TextColor3       = Color3.fromRGB(80, 80, 80)
		youLabel.Font             = Enum.Font.Gotham
		youLabel.TextSize         = 11
		youLabel.TextXAlignment   = Enum.TextXAlignment.Left
	end

	btn.MouseEnter:Connect(function()
		if btn ~= SelectedButton then
			tween(btn, FAST, { BackgroundColor3 = Color3.fromRGB(35, 35, 35) })
		end
	end)
	btn.MouseLeave:Connect(function()
		if btn ~= SelectedButton then
			tween(btn, FAST, { BackgroundColor3 = Color3.fromRGB(28, 28, 28) })
		end
	end)
	btn.MouseButton1Click:Connect(function()
		selectPlayer(plr, btn)
	end)

	return btn
end

for _, p in ipairs(Players:GetPlayers()) do
	local btn = createPlayerButton(p)
	if p == LocalPlayer then
		task.defer(function() selectPlayer(p, btn) end)
	end
end

Players.PlayerAdded:Connect(function(p) createPlayerButton(p) end)

Players.PlayerRemoving:Connect(function(p)
	local btn = PlayerScroll:FindFirstChild("PlayerBtn_" .. p.Name)
	if btn then
		if btn == SelectedButton then
			local fallback = PlayerScroll:FindFirstChild("PlayerBtn_" .. LocalPlayer.Name)
			if fallback then selectPlayer(LocalPlayer, fallback) end
		end
		btn:Destroy()
	end
end)

