-- Format price as "R$ 75" with comma separators for large numbers
local function formatPrice(price)
	if not price then return "" end
	local s = tostring(math.floor(price))
	-- Insert commas
	local result = s:reverse():gsub("(%d%d%d)", "%1,"):reverse()
	result = result:gsub("^,", "")
	return "R$ " .. result
end

