local function createNotification(titleText, bodyText, notifType)
    local CoreGui = game:GetService("CoreGui")
    notifType = notifType or "info" -- "info", "success", "error", "warning"

    local colors = {
        info    = { bg = Color3.fromRGB(25, 25, 40),    accent = Color3.fromRGB(80, 120, 255)  },
        success = { bg = Color3.fromRGB(20, 35, 25),    accent = Color3.fromRGB(50, 200, 100)  },
        error   = { bg = Color3.fromRGB(35, 20, 20),    accent = Color3.fromRGB(220, 60, 60)   },
        warning = { bg = Color3.fromRGB(35, 30, 15),    accent = Color3.fromRGB(240, 180, 30)  },
    }
    local scheme = colors[notifType] or colors.info

    -- Clean up old notifs
    for _, v in ipairs(CoreGui:GetChildren()) do
        if v.Name == "BoothNotif" then v:Destroy() end
    end

    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "BoothNotif"
    screenGui.ResetOnSpawn = false
    screenGui.DisplayOrder = 999
    screenGui.Parent = CoreGui

    -- Shadow
    local shadow = Instance.new("Frame", screenGui)
    shadow.Size = UDim2.new(0, 320, 0, 80)
    shadow.Position = UDim2.new(1, -340, 1, -105)
    shadow.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    shadow.BackgroundTransparency = 0.5
    shadow.BorderSizePixel = 0
    Instance.new("UICorner", shadow).CornerRadius = UDim.new(0, 14)

    -- Main frame
    local frame = Instance.new("Frame", screenGui)
    frame.Size = UDim2.new(0, 320, 0, 80)
    frame.Position = UDim2.new(1, 20, 1, -105) -- starts off screen
    frame.BackgroundColor3 = scheme.bg
    frame.BorderSizePixel = 0
    frame.ClipsDescendants = true
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 14)

    -- Accent bar (left side)
    local accentBar = Instance.new("Frame", frame)
    accentBar.Size = UDim2.new(0, 5, 1, 0)
    accentBar.Position = UDim2.new(0, 0, 0, 0)
    accentBar.BackgroundColor3 = scheme.accent
    accentBar.BorderSizePixel = 0
    Instance.new("UICorner", accentBar).CornerRadius = UDim.new(0, 4)

    -- Progress bar (auto-dismiss timer)
    local progressBg = Instance.new("Frame", frame)
    progressBg.Size = UDim2.new(1, 0, 0, 3)
    progressBg.Position = UDim2.new(0, 0, 1, -3)
    progressBg.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
    progressBg.BorderSizePixel = 0

    local progressBar = Instance.new("Frame", progressBg)
    progressBar.Size = UDim2.new(1, 0, 1, 0)
    progressBar.BackgroundColor3 = scheme.accent
    progressBar.BorderSizePixel = 0

    -- Title
    local title = Instance.new("TextLabel", frame)
    title.Size = UDim2.new(1, -20, 0, 28)
    title.Position = UDim2.new(0, 16, 0, 8)
    title.BackgroundTransparency = 1
    title.Text = titleText
    title.TextColor3 = Color3.fromRGB(255, 255, 255)
    title.Font = Enum.Font.GothamBold
    title.TextSize = 14
    title.TextXAlignment = Enum.TextXAlignment.Left

    -- Body
    local body = Instance.new("TextLabel", frame)
    body.Size = UDim2.new(1, -20, 0, 30)
    body.Position = UDim2.new(0, 16, 0, 36)
    body.BackgroundTransparency = 1
    body.Text = bodyText
    body.TextColor3 = Color3.fromRGB(180, 180, 195)
    body.Font = Enum.Font.Gotham
    body.TextSize = 12
    body.TextWrapped = true
    body.TextXAlignment = Enum.TextXAlignment.Left

    -- Slide IN
    TweenService:Create(frame, TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
        Position = UDim2.new(1, -340, 1, -105)
    }):Play()
    TweenService:Create(shadow, TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
        Position = UDim2.new(1, -336, 1, -101)
    }):Play()

    -- Progress drain
    local DURATION = 4
    TweenService:Create(progressBar, TweenInfo.new(DURATION, Enum.EasingStyle.Linear), {
        Size = UDim2.new(0, 0, 1, 0)
    }):Play()

    -- Auto dismiss
    task.delay(DURATION, function()
        local slideOut = TweenService:Create(frame, TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {
            Position = UDim2.new(1, 20, 1, -105)
        })
        slideOut:Play()
        TweenService:Create(shadow, TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {
            Position = UDim2.new(1, 20, 1, -101)
        }):Play()
        slideOut.Completed:Wait()
        screenGui:Destroy()
    end)
end

