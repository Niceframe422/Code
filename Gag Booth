-- PLACE 1: BOOTH AUTO CLAIM
--------------------------------------------------
if game.PlaceId == 129954712878723 then

    -- Anti-AFK
    task.spawn(function()
        while true do
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F15, false, game)
            task.wait(0.05)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F15, false, game)
            task.wait(math.random(2, 5))
        end
    end)

    local TradeWorld = Workspace:WaitForChild("TradeWorld", 30)
    local Booths     = TradeWorld and TradeWorld:WaitForChild("Booths", 15)
    local Sign       = TradeWorld and TradeWorld:WaitForChild("ArtisanContainerSign", 15)

    if not (TradeWorld and Booths and Sign) then
        createNotification("⚠ Load Error", "World failed to load in time.", "error")
        return
    end

    local ClaimEvent = ReplicatedStorage
        :WaitForChild("GameEvents", 10)
        :WaitForChild("TradeEvents", 10)
        :WaitForChild("Booths", 10)
        :WaitForChild("ClaimBooth", 10)

    -- Safe pivot getter
    local function getPos(model)
        if not model or not model.Parent then return nil end
        local ok, result = pcall(function() return model:GetPivot().Position end)
        return ok and result or nil
    end

    -- Validate booth is truly empty and unclaimed
    local function isBoothEmpty(booth)
        if not booth or not booth.Parent then return false end
        local dynamic = booth:FindFirstChild("DynamicInstances")
        if not dynamic then return false end
        if #dynamic:GetChildren() > 0 then return false end
        -- Extra: check no owner attribute
        if booth:GetAttribute("Owner") ~= nil and booth:GetAttribute("Owner") ~= "" then
            return false
        end
        return true
    end

    -- Find closest valid empty booth to the sign
    local function findBestBooth()
        local signPos = getPos(Sign)
        if not signPos then
            createNotification("⚠ Warning", "Could not locate sign position.", "warning")
            return nil
        end

        local best = nil
        local bestDist = math.huge
        local emptyCount = 0

        for _, booth in ipairs(Booths:GetChildren()) do
            if booth:IsA("Model") and isBoothEmpty(booth) then
                emptyCount += 1
                local pos = getPos(booth)
                if pos then
                    local dist = (pos - signPos).Magnitude
                    if dist < bestDist then
                        bestDist = dist
                        best = booth
                    end
                end
            end
        end

        if emptyCount == 0 then
            createNotification("⏳ No Booths", "All booths are currently claimed.", "warning")
        end

        return best
    end

    -- Main claim loop
    task.spawn(function()
        task.wait(2)
        createNotification("🔍 Searching", "Looking for an empty booth...", "info")

        local attempts = 0
        local maxAttempts = 20

        while attempts < maxAttempts do
            attempts += 1
            local booth = findBestBooth()

            if booth then
                -- Validate still exists before firing
                if not booth.Parent then
                    createNotification("⚠ Invalid", "Booth disappeared, retrying...", "warning")
                    task.wait(2)
                    continue
                end

                print("Attempting claim:", booth.Name, "| Attempt:", attempts)
                createNotification("🎯 Claiming", "Attempting: " .. booth.Name, "info")

                local ok, err = pcall(function()
                    ClaimEvent:FireServer(booth)
                end)

                if not ok then
                    createNotification("❌ Fire Error", tostring(err), "error")
                    task.wait(2)
                    continue
                end

                task.wait(2)

                -- Verify claim succeeded
                local dynamic = booth:FindFirstChild("DynamicInstances")
                if dynamic and #dynamic:GetChildren() > 0 then
                    createNotification("✅ Claimed!", "Successfully claimed: " .. booth.Name, "success")
                    print("✅ Claimed:", booth.Name)
                    break
                else
                    createNotification("❌ Failed", "Claim rejected, retrying... (" .. attempts .. "/" .. maxAttempts .. ")", "error")
                    print("❌ Claim rejected, retrying...")
                end
            end

            task.wait(2)
        end

        if attempts >= maxAttempts then
            createNotification("🚫 Stopped", "Max attempts reached. No booth claimed.", "error")
        end
    end)
end

