local function sortModels(models)
	if sortMode=="name_az" then table.sort(models,function(a,b) return a.Name<b.Name end)
	elseif sortMode=="name_za" then table.sort(models,function(a,b) return a.Name>b.Name end)
	elseif sortMode=="weight_desc" then table.sort(models,function(a,b) return getW(a)>getW(b) end)
	elseif sortMode=="weight_asc" then table.sort(models,function(a,b) return getW(a)<getW(b) end)
	elseif sortMode=="mutations_desc" then table.sort(models,function(a,b) return #getMutations(a)>#getMutations(b) end)
	elseif sortMode=="fruit_desc" then table.sort(models,function(a,b) return getFruitCount(a)>getFruitCount(b) end)
	elseif sortMode=="age_desc" then table.sort(models,function(a,b) return getAge(a)>getAge(b) end) end
end

