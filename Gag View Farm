	local row=Instance.new("Frame",parent)
	row.Size=UDim2.new(1,0,0,28); row.BackgroundTransparency=1; row.BorderSizePixel=0; hlist(row,6)

	if isMine then
		-- Collect button
		local btn=Instance.new("TextButton",row)
		btn.AutomaticSize=Enum.AutomaticSize.X; btn.Size=UDim2.new(0,0,1,0)
		btn.BackgroundColor3=C.collectBg; btn.TextColor3=C.collectTx
		btn.Font=Enum.Font.GothamBold; btn.TextSize=10; btn.Text=" ⬡  Collect "; btn.BorderSizePixel=0; corner(btn,7)
		mkStroke(btn,Color3.fromRGB(30,100,58),0.8)
		btn.MouseEnter:Connect(function() tw(btn,{BackgroundColor3=Color3.fromRGB(14,48,28)}) end)
		btn.MouseLeave:Connect(function() tw(btn,{BackgroundColor3=C.collectBg}) end)
		local cm=model; btn.MouseButton1Click:Connect(function() doCollect(cm) end)
	else
		-- Steal button
		local btn=Instance.new("TextButton",row)
		btn.AutomaticSize=Enum.AutomaticSize.X; btn.Size=UDim2.new(0,0,1,0)
		btn.BackgroundColor3=C.stealBg; btn.TextColor3=C.stealTx
		btn.Font=Enum.Font.GothamBold; btn.TextSize=10; btn.Text=" ⚔  Steal "; btn.BorderSizePixel=0; corner(btn,7)
		mkStroke(btn,Color3.fromRGB(100,28,28),0.8)
		btn.MouseEnter:Connect(function() tw(btn,{BackgroundColor3=Color3.fromRGB(50,14,14)}) end)
		btn.MouseLeave:Connect(function() tw(btn,{BackgroundColor3=C.stealBg}) end)
		local cm=model; btn.MouseButton1Click:Connect(function() doSteal(cm) end)
	end
end

