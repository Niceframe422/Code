------------------------------------------------
-- MAIN LOOP
------------------------------------------------
local lastPlayer = nil
local lastPlantCount = -1

while task.wait(2) do
	local plr = state.selectedPlayer
	if not plr then continue end

	local farm = getFarm(plr)
	local plantsFolder = farm and farm:FindFirstChild("Plants_Physical")
	local count = plantsFolder and #plantsFolder:GetChildren() or 0

	if plr ~= lastPlayer or count ~= lastPlantCount then
		lastPlayer = plr
		lastPlantCount = count
		state.currentPlantsFolder = plantsFolder
		if state.view == "plants" then
			renderPlants()
		end
	end
end
