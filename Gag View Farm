-- ════════════════════════════════════════════
-- WORLD HOVER (works even when UI is hidden)
-- ════════════════════════════════════════════
local lastHoverModel=nil

-- Cache which models belong to which farm/owner (rebuilt periodically)
local farmOwnerCache={}  -- [model] = playerName or "Unknown"
local function rebuildOwnerCache()
	farmOwnerCache={}
	local farms=getAllFarms()
	for _,fd in ipairs(farms) do
		local pf=fd.imp and fd.imp:FindFirstChild("Plants_Physical")
		if not pf then continue end
		local ownerName=fd.player and fd.player.Name or tostring(fd.owner)
		for _,m in ipairs(pf:GetDescendants()) do
			if m:IsA("Model") or m:IsA("BasePart") then
				farmOwnerCache[m]=ownerName
			end
		end
	end
end
rebuildOwnerCache()

local function getOwnerOfModel(model)
	return farmOwnerCache[model] or farmOwnerCache[model.Parent] or nil
end

local function isFromAnyFarm(model)
	-- Check if model is a plant model or fruit in any farm
	local F=workspace:FindFirstChild("Farm"); if not F then return false end
	return model:IsDescendantOf(F)
end

RunService.RenderStepped:Connect(function()
	if not ESP.hoverLabels then
		if hoverPopup.Visible then hoverPopup.Visible=false; lastHoverModel=nil end
		return
	end

	local target=mouse.Target
	local model=target
	if model then
		if model:IsA("BasePart") then model=model.Parent end
		if not (model and model:IsA("Model")) then model=nil end
	end

	if not model or not isFromAnyFarm(model) then
		if hoverPopup.Visible then hoverPopup.Visible=false; lastHoverModel=nil end
		return
	end

	-- Check if owner is blocked
	local ownerName=getOwnerOfModel(model)
	if ownerName then
		for _,plr in ipairs(Players:GetPlayers()) do
			if plr.Name==ownerName and ESP.blockedPlayers[plr.UserId] then
				if hoverPopup.Visible then hoverPopup.Visible=false; lastHoverModel=nil end
				return
			end
		end
	end

	-- Position
	local mp=UIS:GetMouseLocation()
	local vp=camera.ViewportSize
	local px=math.min(mp.X+20, vp.X-248)
	local py=math.min(mp.Y+20, vp.Y-210)
	hoverPopup.Position=UDim2.new(0,px,0,py)

	if model==lastHoverModel then
		hoverPopup.Visible=true; return
	end
	lastHoverModel=model

	-- Rebuild popup
	local muts=getMutations(model)
	local w=getW(model)
	local v=getV(model)
	local isFruit=model.Parent and model.Parent.Name=="Fruits"
	local isMulti=not isFruit and model:FindFirstChild("Fruits")~=nil
	local fc=isMulti and getFruitCount(model) or 0
	local espColor=getESPColor(model,muts)

	hpAccent.BackgroundColor3=espColor
	hpTitle.Text=model.Name
	hpTitle.TextColor3=isFruit and C.textAmber or (isMulti and C.textGreen or C.text)

	if isFruit then
		hpTypeBadge.Text=" 🍎 Fruit "
		hpTypeBadge.BackgroundColor3=Color3.fromRGB(50,32,14)
		hpTypeBadge.TextColor3=C.textAmber
	elseif isMulti then
		hpTypeBadge.Text=" ⬥ Multi · "..fc.." fruits "
		hpTypeBadge.BackgroundColor3=Color3.fromRGB(18,50,34)
		hpTypeBadge.TextColor3=C.textGreen
	else
		hpTypeBadge.Text=" ◆ Single Harvest "
		hpTypeBadge.BackgroundColor3=Color3.fromRGB(34,30,64)
		hpTypeBadge.TextColor3=Color3.fromRGB(150,140,230)
	end

	-- Owner badge
	if ownerName then
		hpOwnerBadge.Text=" 👤 "..ownerName.." "
		hpOwnerBadge.Visible=true
	else
		hpOwnerBadge.Visible=false
	end

	hpWVal.Text=w>0 and string.format("%.4f",w) or "—"
	hpVVal.Text=v or "—"
	hpFruitRow.Visible=isMulti
	if isMulti then hpFLbl.Text="🍃 "..fc.." fruit"..(fc~=1 and "s" or "").." growing" end
	hpMutHLbl.Text="MUTATIONS ("..#muts..")"
	rebuildHpMuts(muts)
	hoverPopup.Visible=true
end)

