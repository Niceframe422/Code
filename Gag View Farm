		end
		local infoL=lbl(card,{size=11,color=isMulti and Color3.fromRGB(78,145,106) or C.textSub,sz=UDim2.new(1,0,0,14)})
		if isMulti then infoL.Text=fc.." fruit"..(fc~=1 and "s" or "").."  ·  tap to expand"
		else
			local parts={}
			if weight then table.insert(parts,string.format("⚖ %.2f",weight.Value)) end
			if #muts>0 then table.insert(parts,"✦ "..#muts.." mut"..( #muts>1 and "s" or "").." (×"..mutTotalMult(muts)..")") end
			infoL.Text=table.concat(parts,"   ")
