local function getESPColor(model, muts)
	if ESP.colorMode=="mutation" then
		return #muts>0 and Color3.fromRGB(205,62,245) or Color3.fromRGB(90,80,180)
	elseif ESP.colorMode=="rarity" then
		local n=#muts
		if n==0 then return Color3.fromRGB(105,105,150)
		elseif n==1 then return Color3.fromRGB(62,160,255)
		elseif n==2 then return Color3.fromRGB(160,62,250)
		else return Color3.fromRGB(255,90,26) end
	else
		if model.Parent and model.Parent.Name=="Fruits" then return Color3.fromRGB(255,174,40) end
		if model:FindFirstChild("Fruits") then return Color3.fromRGB(55,202,122) end
		return Color3.fromRGB(90,80,195)
	end
end

-- Helper: get first BasePart inside a model
local function getModelPart(m)
	if m:IsA("BasePart") then return m end
	return m:IsA("Model") and (m.PrimaryPart or m:FindFirstChildWhichIsA("BasePart")) or nil
end

