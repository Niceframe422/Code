-- Toggle pill builder — returns clickBtn, setState func, getState func
local function miscToggle(labelText, desc, initState, onChange)
	local row=Instance.new("Frame",miscScroll)
	row.Size=UDim2.new(1,0,0,58); row.BackgroundColor3=C.miscCard
	row.BorderSizePixel=0; corner(row,10); stroke(row,C.stroke,0.6)
	local pad=Instance.new("UIPadding",row)
	pad.PaddingLeft=UDim.new(0,10); pad.PaddingRight=UDim.new(0,10)
	pad.PaddingTop=UDim.new(0,9); pad.PaddingBottom=UDim.new(0,9)

	lbl(row,{text=labelText,font=Enum.Font.GothamBold,size=12,color=C.text,sz=UDim2.new(1,-46,0,16)})
	lbl(row,{text=desc,size=9,color=C.textMuted,sz=UDim2.new(1,-46,0,13),pos=UDim2.new(0,0,0,20)})

	local togBg=Instance.new("Frame",row)
	togBg.Size=UDim2.new(0,38,0,20); togBg.Position=UDim2.new(1,-38,0.5,-10)
	togBg.BackgroundColor3=initState and C.toggleOn or C.toggleOff; togBg.BorderSizePixel=0; corner(togBg,10)
	local togDot=Instance.new("Frame",togBg)
	togDot.Size=UDim2.new(0,16,0,16); togDot.Position=UDim2.new(0,initState and 20 or 2,0.5,-8)
	togDot.BackgroundColor3=Color3.fromRGB(255,255,255); togDot.BorderSizePixel=0; corner(togDot,8)

	local state=initState
	local function setState(v)
		state=v
		tw(togBg,{BackgroundColor3=v and C.toggleOn or C.toggleOff})
		tw(togDot,{Position=UDim2.new(0,v and 20 or 2,0.5,-8)})
		if onChange then onChange(v) end
	end

	local clickBtn=Instance.new("TextButton",row)
	clickBtn.Size=UDim2.new(1,0,1,0); clickBtn.BackgroundTransparency=1
	clickBtn.Text=""; clickBtn.BorderSizePixel=0
	clickBtn.MouseButton1Click:Connect(function() setState(not state) end)
	return setState, function() return state end
end

