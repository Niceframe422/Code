function renderPlants()
	clearScroll()
	setControlsVisible(true)
	backBtn.Visible = false
	local plr = state.selectedPlayer
	breadcrumb.Text = plr.Name.."'s Farm"
	headerSub.Text  = "Viewing "..plr.Name.."'s plants"

	local query = string.lower(searchBox.Text)
	local models = {}

	if state.currentPlantsFolder then
		for _, v in ipairs(state.currentPlantsFolder:GetChildren()) do
			if v:IsA("Model") then
				if query == "" or string.find(string.lower(v.Name), query, 1, true) then
					table.insert(models, v)
				end
			end
		end
	else
		emptyLabel("No Plants_Physical folder found.")
		statLbl.Text = ""
		return
	end

	sortModels(models)

	-- Count mutations across all visible plants
	local totalMuts = 0
	for _, m in ipairs(models) do totalMuts += #getMutations(m) end
	statLbl.Text = #models.." plants   "..totalMuts.." mutations"

	if #models == 0 then
		emptyLabel(query ~= "" and 'No plants match "'..query..'".' or "No plants found.")
		return
	end

	-- Count label
	local countLbl = makeLabel(mainScroll, {
		text  = "  "..#models.." PLANT"..(#models ~= 1 and "S" or ""),
		size  = 9,
		color = COLORS.textMuted,
		font  = Enum.Font.GothamBold,
		sz    = UDim2.new(1, 0, 0, 14),
	})

	for _, model in ipairs(models) do
		local fruitsFolder = model:FindFirstChild("Fruits")
		local isMulti = fruitsFolder ~= nil
		local mutations, variant, weight = {}, nil, nil

		if not isMulti then
			variant   = model:FindFirstChild("Variant")
			weight    = model:FindFirstChild("Weight")
			mutations = getMutations(model)
		end
		local fruitCount = isMulti and #fruitsFolder:GetChildren() or 0

		local card, stroke = makeCard(mainScroll, isMulti)

		local row1 = Instance.new("Frame", card)
		row1.Size = UDim2.new(1, 0, 0, 20)
		row1.BackgroundTransparency = 1

		makeLabel(row1, {
			text     = model.Name,
			font     = Enum.Font.GothamBold,
			size     = 14,
			color    = COLORS.textPrimary,
			sz       = UDim2.new(1, -100, 1, 0),
			truncate = Enum.TextTruncate.AtEnd,
		})

		local badge = Instance.new("TextLabel", row1)
		badge.Size = UDim2.new(0, 90, 0, 17)
		badge.Position = UDim2.new(1, -90, 0.5, -8)
		badge.BorderSizePixel = 0
		badge.Font = Enum.Font.GothamBold
		badge.TextSize = 9
		uiCorner(badge, 9)
		if isMulti then
			badge.BackgroundColor3 = Color3.fromRGB(20, 58, 40)
			badge.TextColor3 = Color3.fromRGB(70, 210, 135)
			badge.Text = "Multi-Harvest"
		else
			badge.BackgroundColor3 = Color3.fromRGB(40, 36, 72)
			badge.TextColor3 = Color3.fromRGB(155, 145, 240)
			badge.Text = "Single Harvest"
		end

		local infoLbl = makeLabel(card, {
			size  = 11,
			color = isMulti and Color3.fromRGB(85, 155, 110) or COLORS.textSub,
			sz    = UDim2.new(1, 0, 0, 14),
		})
		if isMulti then
			infoLbl.Text = fruitCount.." fruit"..(fruitCount ~= 1 and "s" or "").."  —  tap to expand"
		else
			local parts = {}
			if variant then table.insert(parts, "Variant: "..tostring(variant.Value)) end
			if weight  then table.insert(parts, "Weight: "..string.format("%.2f", weight.Value)) end
			infoLbl.Text = table.concat(parts, "   ")
		end

		if not isMulti and #mutations > 0 then
			makeMutationPills(card, mutations)
		end

		local hoverBg = isMulti and COLORS.cardHoverMH or COLORS.cardHoverSH
		local hoverStroke = isMulti and COLORS.strokeGreenHi or COLORS.strokeHi
		local defaultStroke = isMulti and COLORS.strokeGreen or COLORS.stroke

		card.MouseEnter:Connect(function()
			tween(card,   {BackgroundColor3 = hoverBg})
			tween(stroke, {Color = hoverStroke})
		end)
		card.MouseLeave:Connect(function()
			tween(card,   {BackgroundColor3 = COLORS.card})
			tween(stroke, {Color = defaultStroke})
		end)

		local capturedModel = model
		card.MouseButton1Click:Connect(function()
			if isMulti then
				state.view = "fruits"
				state.currentPlantModel = capturedModel
				searchBox.Text = ""
				renderFruits()
			end
		end)
	end
end

function renderFruits()
	clearScroll()
	setControlsVisible(true)
	backBtn.Visible = true
	local plantModel = state.currentPlantModel
	breadcrumb.Text = plantModel.Name.." / Fruits"

	local fruitsFolder = plantModel:FindFirstChild("Fruits")
	if not fruitsFolder then
		emptyLabel("No Fruits folder found.")
		statLbl.Text = ""
		return
	end

	local query = string.lower(searchBox.Text)
	local fruits = {}
	for _, v in ipairs(fruitsFolder:GetChildren()) do
		if query == "" or string.find(string.lower(v.Name), query, 1, true) then
			table.insert(fruits, v)
		end
	end

	sortModels(fruits)

	local totalMuts = 0
	for _, f in ipairs(fruits) do totalMuts += #getMutations(f) end
	statLbl.Text = #fruits.." fruits   "..totalMuts.." mutations"

	local sectionText = "  "..#fruits.." FRUIT"..(#fruits ~= 1 and "S" or "").." IN "..string.upper(plantModel.Name)
	if query ~= "" then sectionText = sectionText..'  —  "'..query..'"' end
	makeLabel(mainScroll, {
		text  = sectionText,
		size  = 9,
		color = COLORS.textMuted,
		font  = Enum.Font.GothamBold,
		sz    = UDim2.new(1, 0, 0, 16),
	})

	if #fruits == 0 then
		emptyLabel(query ~= "" and 'No fruits match "'..query..'".' or "No fruits yet.")
		return
	end

	for _, fruitModel in ipairs(fruits) do
		local variant   = fruitModel:FindFirstChild("Variant")
		local weight    = fruitModel:FindFirstChild("Weight")
		local mutations = getMutations(fruitModel)

		local card, stroke = makeCard(mainScroll, true)

		local row1 = Instance.new("Frame", card)
		row1.Size = UDim2.new(1, 0, 0, 20)
		row1.BackgroundTransparency = 1

		makeLabel(row1, {
			text     = fruitModel.Name,
			font     = Enum.Font.GothamBold,
			size     = 14,
			color    = COLORS.textGreen,
			sz       = UDim2.new(0.68, 0, 1, 0),
			truncate = Enum.TextTruncate.AtEnd,
		})

		if #mutations > 0 then
			local mutBadge = Instance.new("TextLabel", row1)
			mutBadge.Size = UDim2.new(0, 82, 0, 17)
			mutBadge.Position = UDim2.new(1, -82, 0.5, -8)
			mutBadge.BackgroundColor3 = COLORS.mutPill
			mutBadge.TextColor3 = COLORS.mutPillText
			mutBadge.Font = Enum.Font.GothamBold
			mutBadge.TextSize = 9
			mutBadge.Text = #mutations.." mutation"..(#mutations > 1 and "s" or "")
			mutBadge.BorderSizePixel = 0
			uiCorner(mutBadge, 9)
		end

		local parts = {}
		if variant then table.insert(parts, "Variant: "..tostring(variant.Value)) end
		if weight  then table.insert(parts, "Weight: "..string.format("%.2f", weight.Value)) end
		if #parts > 0 then
			makeLabel(card, {
				text  = table.concat(parts, "   "),
				size  = 11,
				color = Color3.fromRGB(90, 150, 115),
				sz    = UDim2.new(1, 0, 0, 14),
			})
		end

		if #mutations > 0 then
			makeMutationPills(card, mutations)
		end

		card.MouseEnter:Connect(function()
			tween(card,   {BackgroundColor3 = COLORS.cardHoverMH})
			tween(stroke, {Color = COLORS.strokeGreenHi})
		end)
		card.MouseLeave:Connect(function()
			tween(card,   {BackgroundColor3 = COLORS.card})
			tween(stroke, {Color = COLORS.strokeGreen})
		end)

		local capturedFruit = fruitModel
		card.MouseButton1Click:Connect(function()
			state.view = "detail"
			state.currentFruitModel = capturedFruit
			renderDetail()
		end)
	end
end

function renderDetail()
	clearScroll()
	setControlsVisible(false)
	backBtn.Visible = true
	statLbl.Text = ""
	local fruitModel = state.currentFruitModel
	local plantName  = state.currentPlantModel and state.currentPlantModel.Name or "?"
	breadcrumb.Text  = plantName.." / "..fruitModel.Name

	local variant   = fruitModel:FindFirstChild("Variant")
	local weight    = fruitModel:FindFirstChild("Weight")
	local mutations = getMutations(fruitModel)

	-- Fetch all attributes for a full dump
	local allAttrs = {}
	local ok, attrs = pcall(function() return fruitModel:GetAttributes() end)
	if ok then
		for k, v in pairs(attrs) do
			if not EXCLUDED_ATTRS[k] then
				table.insert(allAttrs, {name=k, value=v})
			end
		end
		table.sort(allAttrs, function(a,b) return a.name < b.name end)
	end

	local card = Instance.new("Frame", mainScroll)
	card.Size = UDim2.new(1, -4, 0, 0)
	card.AutomaticSize = Enum.AutomaticSize.Y
	card.BackgroundColor3 = COLORS.card
	card.BorderSizePixel = 0
	uiCorner(card, 10)
	uiStroke(card, COLORS.stroke)
	local pad = Instance.new("UIPadding", card)
	pad.PaddingTop = UDim.new(0, 14)
	pad.PaddingBottom = UDim.new(0, 14)
	pad.PaddingLeft = UDim.new(0, 14)
	pad.PaddingRight = UDim.new(0, 14)
	local layout = Instance.new("UIListLayout", card)
	layout.Padding = UDim.new(0, 10)

	makeLabel(card, {
		text  = fruitModel.Name,
		font  = Enum.Font.GothamBold,
		size  = 16,
		color = COLORS.textGreen,
		sz    = UDim2.new(1, 0, 0, 22),
	})

	-- divider
	local function divider()
		local d = Instance.new("Frame", card)
		d.Size = UDim2.new(1, 0, 0, 1)
		d.BackgroundColor3 = Color3.fromRGB(38, 36, 60)
		d.BorderSizePixel = 0
	end

	divider()

	local function sectionHeader(text)
		makeLabel(card, {
			text  = text,
			size  = 9,
			color = COLORS.textSub,
			font  = Enum.Font.GothamBold,
			sz    = UDim2.new(1, 0, 0, 14),
		})
	end

	local function fieldRow(label, value, valColor)
		local row = Instance.new("Frame", card)
		row.Size = UDim2.new(1, 0, 0, 28)
		row.BackgroundColor3 = Color3.fromRGB(24, 23, 38)
		row.BorderSizePixel = 0
		uiCorner(row, 6)
		makeLabel(row, {
			text  = label,
			size  = 12,
			color = COLORS.textSub,
			sz    = UDim2.new(0.42, 0, 1, 0),
			pos   = UDim2.new(0, 10, 0, 0),
		})
		makeLabel(row, {
			text  = tostring(value),
			font  = Enum.Font.GothamBold,
			size  = 12,
			color = valColor or COLORS.textPrimary,
			sz    = UDim2.new(0.54, 0, 1, 0),
			pos   = UDim2.new(0.44, 0, 0, 0),
		})
	end

	sectionHeader("PROPERTIES")
	if variant then fieldRow("Variant", variant.Value, Color3.fromRGB(155, 215, 255)) end
	if weight  then fieldRow("Weight", string.format("%.4f", weight.Value), Color3.fromRGB(255, 205, 110)) end

	-- Extra non-boolean attributes
	local extraAttrs = {}
	if ok then
		for k, v in pairs(attrs) do
			if type(v) ~= "boolean" and k ~= "Weight" and k ~= "Variant" and not EXCLUDED_ATTRS[k] then
				table.insert(extraAttrs, {name=k, value=v})
			end
		end
		table.sort(extraAttrs, function(a,b) return a.name < b.name end)
	end
	for _, entry in ipairs(extraAttrs) do
		fieldRow(entry.name, tostring(entry.value))
	end

	divider()
	sectionHeader("MUTATIONS ("..#mutations..")")

	if #mutations == 0 then
		makeLabel(card, {
			text  = "None detected",
			size  = 13,
			color = COLORS.textMuted,
			sz    = UDim2.new(1, 0, 0, 20),
		})
	else
		makeMutationPills(card, mutations)
	end
end

