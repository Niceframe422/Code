-- MAIN LOOP (polling, owner cache refresh)
-- ════════════════════════════════════════════
local lastPlr=nil; local lastCount=-1

while task.wait(ESP.refreshRate) do
	-- Refresh owner cache every cycle
	rebuildOwnerCache()

	for plr in pairs(plrBtnData) do refreshSubLbl(plr) end

	local plr=stateRef.selectedPlayer; if not plr then continue end
	local farm=getFarmForPlayer(plr)
	local pf=farm and farm:FindFirstChild("Plants_Physical")
	local count=pf and #pf:GetChildren() or 0

	if plr~=lastPlr or count~=lastCount then
		lastPlr=plr; lastCount=count
		stateRef.currentPlantsFolder=pf
		if stateRef.view=="plants" then renderPlants() end
		if ESP.enabled then refreshESP() end
	end
end
