function renderPlants()
	clearScroll(); setControlsVisible(true); backBtn.Visible=false
	local plr=stateRef.selectedPlayer
	breadcrumb.Text=plr.Name.."'s Farm"
	headerSub.Text="Viewing "..plr.Name.."'s plants"
	local q=string.lower(searchBox.Text); local models={}
	if stateRef.currentPlantsFolder then
		for _,v in ipairs(stateRef.currentPlantsFolder:GetChildren()) do
			if v:IsA("Model") then
				local nm=q=="" or string.find(string.lower(v.Name),q,1,true)
				local mm=not mutationsOnly or #getMutations(v)>0
				if nm and mm then table.insert(models,v) end
			end
		end
	else emptyLbl("No Plants_Physical folder found."); statLbl.Text=""; return end

	sortModels(models)
	local totalMuts,totalFruits=0,0
	for _,m in ipairs(models) do totalMuts+=#getMutations(m); totalFruits+=getFruitCount(m) end
	statLbl.Text=#models.." plants  ·  "..totalMuts.." mutations  ·  "..totalFruits.." fruits"
	if #models==0 then emptyLbl(q~="" and 'No match for "'..q..'".' or "No plants found."); return end

	lbl(mainScroll,{text="  "..#models.." PLANT"..(#models~=1 and "S" or ""),size=9,color=C.textMuted,
		font=Enum.Font.GothamBold,sz=UDim2.new(1,0,0,14)})

	for _,model in ipairs(models) do
		local ff=model:FindFirstChild("Fruits"); local isMulti=ff~=nil
		local muts,weight={},nil
		if not isMulti then weight=model:FindFirstChild("Weight"); muts=getMutations(model) end
		local variant=model:FindFirstChild("Variant")
		local fc=isMulti and #ff:GetChildren() or 0
		local card,s=makeCard(mainScroll,isMulti)

		local row1=Instance.new("Frame",card); row1.Size=UDim2.new(1,0,0,20); row1.BackgroundTransparency=1
		lbl(row1,{text=model.Name,font=Enum.Font.GothamBold,size=14,color=C.text,sz=UDim2.new(1,-108,1,0),trunc=Enum.TextTruncate.AtEnd})

		local badge=Instance.new("TextLabel",row1)
		badge.Size=UDim2.new(0,96,0,17); badge.Position=UDim2.new(1,-96,0.5,-8)
		badge.BorderSizePixel=0; badge.Font=Enum.Font.GothamBold; badge.TextSize=9; corner(badge,9)
		if isMulti then badge.BackgroundColor3=Color3.fromRGB(18,54,38); badge.TextColor3=Color3.fromRGB(68,205,130); badge.Text="⬥ Multi-Harvest"
		else badge.BackgroundColor3=Color3.fromRGB(38,34,68); badge.TextColor3=Color3.fromRGB(150,140,235); badge.Text="◆ Single Harvest" end

		local infoL=lbl(card,{size=11,color=isMulti and Color3.fromRGB(82,148,108) or C.textSub,sz=UDim2.new(1,0,0,14)})
		if isMulti then infoL.Text=fc.." fruit"..(fc~=1 and "s" or "").."  ·  tap to expand"
		else
			local parts={}
			if variant then table.insert(parts,"Variant: "..tostring(variant.Value)) end
			if weight then table.insert(parts,string.format("⚖ %.2f",weight.Value)) end
			infoL.Text=table.concat(parts,"   ")
		end
		if not isMulti and #muts>0 then makePills(card,muts) end

		local hBg=isMulti and C.cardHoverMH or C.cardHoverSH
		local hS=isMulti and C.strokeGreenHi or C.strokeHi
		local dS=isMulti and C.strokeGreen or C.stroke
		card.MouseEnter:Connect(function() tw(card,{BackgroundColor3=hBg}); tw(s,{Color=hS}) end)
		card.MouseLeave:Connect(function() tw(card,{BackgroundColor3=C.card}); tw(s,{Color=dS}) end)

		if isMulti then
			local cm=model
			card.MouseButton1Click:Connect(function()
				stateRef.view="fruits"; stateRef.currentPlantModel=cm; searchBox.Text=""; renderFruits()
			end)
		end
	end
end

function renderFruits()
	clearScroll(); setControlsVisible(true); backBtn.Visible=true
	local pm=stateRef.currentPlantModel; breadcrumb.Text=pm.Name.." / Fruits"
	local ff=pm:FindFirstChild("Fruits")
	if not ff then emptyLbl("No Fruits folder."); statLbl.Text=""; return end
	local q=string.lower(searchBox.Text); local fruits={}
	for _,v in ipairs(ff:GetChildren()) do
		local nm=q=="" or string.find(string.lower(v.Name),q,1,true)
		local mm=not mutationsOnly or #getMutations(v)>0
		if nm and mm then table.insert(fruits,v) end
	end
	sortModels(fruits)
	local tm=0; for _,f in ipairs(fruits) do tm+=#getMutations(f) end
	statLbl.Text=#fruits.." fruits  ·  "..tm.." mutations"
