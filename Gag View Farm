	btn.MouseEnter:Connect(function()
		if state.selectedPlayer ~= plr then
			tween(bStroke, {Color = Color3.fromRGB(80, 75, 130)})
		end
	end)
	btn.MouseLeave:Connect(function()
		if state.selectedPlayer ~= plr then
			tween(bStroke, {Color = COLORS.stroke})
		end
	end)
	btn.MouseButton1Click:Connect(function()
		state.selectedPlayer = plr
		-- reset other button strokes
		for p, d in pairs(plrBtnData) do
			tween(d.stroke, {Color = p == plr and COLORS.strokeHi or COLORS.stroke})
		end
		state.view = "plants"
		searchBox.Text = ""
		local farm = getFarm(plr)
		state.currentPlantsFolder = farm and farm:FindFirstChild("Plants_Physical") or nil
		renderPlants()
	end)

	return btn
end

