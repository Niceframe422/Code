local function clearScroll()
	mainScroll.CanvasPosition = Vector2.new(0, 0)
	for _, v in ipairs(mainScroll:GetChildren()) do
		if not v:IsA("UIListLayout") and not v:IsA("UIPadding") then
			v:Destroy()
		end
	end
end

local function sortModels(models)
	if sortMode == "name_az" then
		table.sort(models, function(a,b) return a.Name < b.Name end)
	elseif sortMode == "name_za" then
		table.sort(models, function(a,b) return a.Name > b.Name end)
	elseif sortMode == "weight_desc" then
		table.sort(models, function(a,b)
			local wa = a:FindFirstChild("Weight")
			local wb = b:FindFirstChild("Weight")
			return (wa and wa.Value or 0) > (wb and wb.Value or 0)
		end)
	elseif sortMode == "weight_asc" then
		table.sort(models, function(a,b)
			local wa = a:FindFirstChild("Weight")
			local wb = b:FindFirstChild("Weight")
			return (wa and wa.Value or 0) < (wb and wb.Value or 0)
		end)
	elseif sortMode == "mutations_desc" then
		table.sort(models, function(a,b)
			return #getMutations(a) > #getMutations(b)
		end)
	end
end

