local function clearESP()
	for model,d in pairs(espObjects) do
		-- Remove Highlight from inside model
		if d.hl and d.hl.Parent then pcall(function() d.hl:Destroy() end) end
		if d.bb and d.bb.Parent then pcall(function() d.bb:Destroy() end) end
	end
	espObjects={}
end

local function applyToModel(model, col, isMulti, variant)
	if espObjects[model] then return end
	local muts=getMutations(model); local w=getW(model); local fc=getFruitCount(model)
	local d={}

	-- ── Roblox Highlight (inserted INTO the model/part)
	local hlOk,hl=pcall(function()
		local h=Instance.new("Highlight")
		h.FillColor=col
		h.OutlineColor=col
		if ESP.style=="outline" then
			h.FillTransparency=1
			h.OutlineTransparency=0.15
		elseif ESP.style=="fill" then
			h.FillTransparency=0.55
			h.OutlineTransparency=1
		else -- both
			h.FillTransparency=0.72
			h.OutlineTransparency=0.15
		end
		if ESP.chams then
			pcall(function() h.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop end)
		end
		h.Parent=model   -- parented inside the model so it adorns itself
		return h
	end)
	if hlOk then d.hl=hl end

	if ESP.billboards then
		d.bb=makeBillboard(model,col,model.Name,w,muts,isMulti,fc,variant)
	end
	espObjects[model]=d
end

-- Now assign refreshESP (upvalue is now live)
refreshESP = function()
	clearESP(); if not ESP.enabled then return end
	for _,fd in ipairs(getAllFarms()) do
		if fd.player and ESP.blocked[fd.player.UserId] then continue end
		local pf=fd.imp and fd.imp:FindFirstChild("Plants_Physical"); if not pf then continue end
		for _,model in ipairs(pf:GetChildren()) do
			if not model:IsA("Model") then continue end
			local muts=getMutations(model); local col=getESPColor(model,muts)
			local isMulti=model:FindFirstChild("Fruits")~=nil
			applyToModel(model,col,isMulti,getVariant(model))
			if isMulti then
				local ff=model:FindFirstChild("Fruits")
				if ff then
					for _,fruit in ipairs(ff:GetChildren()) do
						if fruit:IsA("Model") then
							local fm=getMutations(fruit)
							applyToModel(fruit,getESPColor(fruit,fm),false,getVariant(fruit))
						end
					end
				end
			end
		end
	end
end

