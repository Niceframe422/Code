	lbl(card,{text=fm.Name,font=Enum.Font.GothamBold,size=16,color=C.textGreen,sz=UDim2.new(1,0,0,22)})

	local function div() local d=Instance.new("Frame",card); d.Size=UDim2.new(1,0,0,1); d.BackgroundColor3=Color3.fromRGB(36,34,58); d.BorderSizePixel=0 end
	local function secH(t) lbl(card,{text=t,size=9,color=C.textSub,font=Enum.Font.GothamBold,sz=UDim2.new(1,0,0,14)}) end
	local function fieldRow(label,value,vc)
		local row=Instance.new("Frame",card); row.Size=UDim2.new(1,0,0,28)
		row.BackgroundColor3=Color3.fromRGB(22,21,36); row.BorderSizePixel=0; corner(row,6)
		lbl(row,{text=label,size=12,color=C.textSub,sz=UDim2.new(0.42,0,1,0),pos=UDim2.new(0,10,0,0)})
		lbl(row,{text=tostring(value),font=Enum.Font.GothamBold,size=12,color=vc or C.text,
			sz=UDim2.new(0.54,0,1,0),pos=UDim2.new(0.44,0,0,0)})
	end

	div(); secH("PROPERTIES")
	if variant then fieldRow("Variant",variant.Value,Color3.fromRGB(150,210,255)) end
	if weight then fieldRow("Weight",string.format("%.4f",weight.Value),C.textAmber) end
	if ok then
		local extras={}
		for k,v in pairs(attrs) do
			if type(v)~="boolean" and k~="Weight" and k~="Variant" and not EXCLUDED_ATTRS[k] then
				table.insert(extras,{name=k,value=v})
			end
		end
		table.sort(extras,function(a,b)return a.name<b.name end)
		for _,e in ipairs(extras) do fieldRow(e.name,tostring(e.value)) end
	end

	div(); secH("MUTATIONS ("..#muts..")")
	if #muts==0 then
		lbl(card,{text="None detected",size=13,color=C.textMuted,sz=UDim2.new(1,0,0,20)})
	else
		makePills(card,muts)
	end
end

