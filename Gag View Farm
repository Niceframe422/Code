local function getMutations(model)
	local out={}
	local ok,attrs=pcall(function() return model:GetAttributes() end)
	if not ok then return out end
	for name,value in pairs(attrs) do
		if type(value)=="boolean" and not EXCLUDED_ATTRS[name] then
			table.insert(out,name)
		end
	end
	table.sort(out); return out
end

local function getAllFarms()
	local F=workspace:FindFirstChild("Farm"); if not F then return {} end
	local out={}
	for _,farm in pairs(F:GetChildren()) do
		local imp=farm:FindFirstChild("Important")
		local data=imp and imp:FindFirstChild("Data")
		local own=data and data:FindFirstChild("Owner")
		if own then
			local uid=tonumber(own.Value) or 0
			local name=tostring(own.Value)
			-- find matching player
			local plr=nil
			for _,p in ipairs(Players:GetPlayers()) do
				if p.UserId==uid or p.Name==name then plr=p; break end
			end
			table.insert(out,{imp=imp, owner=own.Value, player=plr})
		end
	end
	return out
end

local function getFarmForPlayer(plr)
	local F=workspace:FindFirstChild("Farm"); if not F then return nil end
	for _,farm in pairs(F:GetChildren()) do
		local imp=farm:FindFirstChild("Important")
		local data=imp and imp:FindFirstChild("Data")
		local own=data and data:FindFirstChild("Owner")
		if own and (own.Value==plr.UserId or own.Value==plr.Name) then return imp end
	end
end

local function getW(m) local w=m:FindFirstChild("Weight"); return w and w.Value or 0 end
local function getV(m) local v=m:FindFirstChild("Variant"); return v and tostring(v.Value) or nil end
local function getFruitCount(m) local f=m:FindFirstChild("Fruits"); return f and #f:GetChildren() or 0 end
local function getAge(m) local a=m:FindFirstChild("Age") or m:FindFirstChild("GrowTime"); return a and a.Value or 0 end
local function initials(name) return string.upper(string.sub(name,1,2)) end

local function debounce(fn,delay)
	local t
	return function(...)
		local a={...}; if t then task.cancel(t) end
		t=task.delay(delay,function() fn(table.unpack(a)) end)
	end
end

local function getESPColor(model, mutations)
	if ESP.colorMode=="mutation" then
		return #mutations>0 and C.espMut or Color3.fromRGB(100,95,170)
	elseif ESP.colorMode=="rarity" then
		local mc=#mutations
		if mc==0 then return Color3.fromRGB(120,120,160)
		elseif mc==1 then return Color3.fromRGB(70,170,255)
		elseif mc==2 then return Color3.fromRGB(170,70,255)
		else return Color3.fromRGB(255,100,30) end
	else
		local isFruit=model.Parent and model.Parent.Name=="Fruits"
		if isFruit then return C.espFruit end
		local isMulti=model:FindFirstChild("Fruits")~=nil
		return isMulti and Color3.fromRGB(60,210,130) or Color3.fromRGB(100,90,220)
	end
end

