renderPlants = function()
	clearScroll(); setControls(true); backBtn.Visible=false
	local plr=state.selectedPlayer
	if not plr or not plr.Parent then emptyMsg("Player disconnected."); statLbl.Text=""; return end
	local isMine=(plr==player)
	breadcrumb.Text=plr.Name.."'s Farm"
	hSub.Text=(isMine and "Your" or plr.Name.."'s").." farm"
	local q=string.lower(searchBox.Text); local models={}
	if state.plantsFolder and state.plantsFolder.Parent then
		for _,v in ipairs(state.plantsFolder:GetChildren()) do
			if v:IsA("Model") and (q=="" or string.find(string.lower(v.Name),q,1,true)) then
				if not mutOnly or #getMutations(v)>0 then table.insert(models,v) end
			end
		end
	else emptyMsg("No Plants_Physical folder found."); statLbl.Text=""; return end
	sortModels(models)
	local tm,tf=0,0
	for _,m in ipairs(models) do tm=tm+#getMutations(m); tf=tf+getFruitCount(m) end
	statLbl.Text=#models.." plants  ·  "..tm.." muts  ·  "..tf.." fruits"
	if #models==0 then emptyMsg(q~="" and 'No results for "'..q..'".' or "No plants found."); return end
	lbl(mainScroll,{text="  "..#models.." PLANT"..(#models~=1 and "S" or ""),size=9,color=C.textDim,font=Enum.Font.GothamBold,sz=UDim2.new(1,0,0,14)})
	for _,model in ipairs(models) do
		local ff=model:FindFirstChild("Fruits"); local isMulti=ff~=nil
		local muts=isMulti and {} or getMutations(model)
		local weight=model:FindFirstChild("Weight"); local variant=getVariant(model)
		local fc=isMulti and #ff:GetChildren() or 0
		local card,s=makeCard(mainScroll,isMulti)
		local row1=Instance.new("Frame",card); row1.Size=UDim2.new(1,0,0,20); row1.BackgroundTransparency=1
		lbl(row1,{text=model.Name,font=Enum.Font.GothamBold,size=14,color=C.text,sz=UDim2.new(1,-106,1,0),trunc=Enum.TextTruncate.AtEnd})
		local typeBadge=Instance.new("TextLabel",row1)
		typeBadge.Size=UDim2.new(0,96,0,17); typeBadge.Position=UDim2.new(1,-96,0.5,-8)
		typeBadge.BorderSizePixel=0; typeBadge.Font=Enum.Font.GothamBold; typeBadge.TextSize=9; corner(typeBadge,9)
		if isMulti then typeBadge.BackgroundColor3=Color3.fromRGB(12,48,32); typeBadge.TextColor3=C.textGreen; typeBadge.Text="⬥ Multi-Harvest"
		else typeBadge.BackgroundColor3=Color3.fromRGB(32,28,60); typeBadge.TextColor3=Color3.fromRGB(140,132,222); typeBadge.Text="◆ Single" end
		if not isMulti and variant then
			local vRow=Instance.new("Frame",card); vRow.Size=UDim2.new(1,0,0,0); vRow.AutomaticSize=Enum.AutomaticSize.Y
			vRow.BackgroundTransparency=1; vRow.BorderSizePixel=0; hlist(vRow,4)
			makeVariantBadge(vRow,variant)
		end
		local infoL=lbl(card,{size=11,color=isMulti and Color3.fromRGB(75,140,103) or C.textSub,sz=UDim2.new(1,0,0,14)})
		if isMulti then infoL.Text=fc.." fruit"..(fc~=1 and "s" or "").."  ·  tap to expand"
		else
			local parts={}
			if weight then table.insert(parts,string.format("⚖ %.2f",weight.Value)) end
			if #muts>0 then table.insert(parts,"✦ "..#muts.." mut"..(#muts>1 and "s" or "").." (×"..mutTotalMult(muts)..")") end
			infoL.Text=table.concat(parts,"   ")
		end
		if not isMulti and #muts>0 then makePills(card,muts,true) end
		-- Action row
		makeActionRow(card,model,isMine)
		local hBg=isMulti and C.hoverG or C.hover; local hS=isMulti and C.strokeGHi or C.strokeHi; local dS=isMulti and C.strokeG or C.stroke
		card.MouseEnter:Connect(function() tw(card,{BackgroundColor3=hBg}); tw(s,{Color=hS}) end)
		card.MouseLeave:Connect(function() tw(card,{BackgroundColor3=C.card}); tw(s,{Color=dS}) end)
		if isMulti then
			local cm=model; card.MouseButton1Click:Connect(function()
				state.view="fruits"; state.plantModel=cm; searchBox.Text=""; renderFruits()
			end)
		end
	end
end

renderFruits = function()
