end

local function makeESPBillboard(model, espColor, name, weight, mutations, isMulti, fruitCount)
	local part=getOrMakePrimary(model); if not part then return nil end
	local compact=ESP.billboardDetail=="compact"
	local bb=Instance.new("BillboardGui",part)
	bb.AlwaysOnTop=true
	bb.Size=UDim2.new(0,compact and 145 or 196, 0, compact and 50 or 90)
	bb.StudsOffset=Vector3.new(0,5.5,0); bb.MaxDistance=180

	local frame=Instance.new("Frame",bb)
	frame.Size=UDim2.new(1,0,1,0); frame.BackgroundColor3=Color3.fromRGB(9,9,17)
	frame.BackgroundTransparency=0.10; frame.BorderSizePixel=0; corner(frame,10)
	stroke(frame,espColor,1.8)

	local accentBar=Instance.new("Frame",frame)
	accentBar.Size=UDim2.new(1,-14,0,2); accentBar.Position=UDim2.new(0,7,0,5)
	accentBar.BackgroundColor3=espColor; accentBar.BorderSizePixel=0; corner(accentBar,1)

	local pad=Instance.new("UIPadding",frame)
	pad.PaddingLeft=UDim.new(0,8); pad.PaddingRight=UDim.new(0,8)
	pad.PaddingTop=UDim.new(0,13); pad.PaddingBottom=UDim.new(0,5)
	local layout=Instance.new("UIListLayout",frame); layout.Padding=UDim.new(0,3)

	local nameL=Instance.new("TextLabel",frame)
	nameL.Size=UDim2.new(1,0,0,16); nameL.BackgroundTransparency=1
	nameL.Font=Enum.Font.GothamBold; nameL.TextSize=12
	nameL.TextColor3=isMulti and C.textGreen or C.text
	nameL.Text=name; nameL.TextXAlignment=Enum.TextXAlignment.Left
	nameL.TextTruncate=Enum.TextTruncate.AtEnd

	if not compact then
		local weightL=Instance.new("TextLabel",frame)
		weightL.Size=UDim2.new(1,0,0,12); weightL.BackgroundTransparency=1
		weightL.Font=Enum.Font.Gotham; weightL.TextSize=10; weightL.TextColor3=C.textAmber
		weightL.Text="⚖ "..string.format("%.3f",weight)..(isMulti and "  🍃 "..fruitCount.."f" or "")
		weightL.TextXAlignment=Enum.TextXAlignment.Left

		if #mutations>0 then
			local mutL=Instance.new("TextLabel",frame)
			mutL.Size=UDim2.new(1,0,0,12); mutL.BackgroundTransparency=1
			mutL.Font=Enum.Font.Gotham; mutL.TextSize=10; mutL.TextColor3=C.mutPillTxt
			local first2=mutations[1]..(mutations[2] and ", "..mutations[2] or "")
			if #mutations>2 then first2=first2.." +"..( #mutations-2) end
			mutL.Text="✦ "..first2; mutL.TextXAlignment=Enum.TextXAlignment.Left
			mutL.TextTruncate=Enum.TextTruncate.AtEnd
		else
			local noMutL=Instance.new("TextLabel",frame)
			noMutL.Size=UDim2.new(1,0,0,12); noMutL.BackgroundTransparency=1
			noMutL.Font=Enum.Font.Gotham; noMutL.TextSize=10; noMutL.TextColor3=C.textMuted
			noMutL.Text="◦ No mutations"; noMutL.TextXAlignment=Enum.TextXAlignment.Left
		end
	else
		local compL=Instance.new("TextLabel",frame)
		compL.Size=UDim2.new(1,0,0,12); compL.BackgroundTransparency=1
		compL.Font=Enum.Font.Gotham; compL.TextSize=10; compL.TextColor3=C.textSub
		compL.Text="⚖"..string.format("%.2f",weight).."  ✦"..(#mutations)
		compL.TextXAlignment=Enum.TextXAlignment.Left
	end
	return bb
end

local function clearESP()
	for _,data in pairs(espObjects) do
		if data.selBox then pcall(function() data.selBox:Destroy() end) end
		if data.hl then pcall(function() data.hl:Destroy() end) end
		if data.bb then pcall(function() data.bb:Destroy() end) end
	end
	espObjects={}
end

function refreshESP()
	clearESP()
	if not ESP.enabled then return end

	local farms=getAllFarms()
	for _,farmData in ipairs(farms) do
		-- Check block list
		local ownerPlayer=farmData.player
		if ownerPlayer and ESP.blockedPlayers[ownerPlayer.UserId] then continue end

		local pf=farmData.imp and farmData.imp:FindFirstChild("Plants_Physical")
		if not pf then continue end

		for _, model in ipairs(pf:GetChildren()) do
			if not model:IsA("Model") then continue end
			if espObjects[model] then continue end

			local muts=getMutations(model)
			local espColor=getESPColor(model,muts)
			local isMulti=model:FindFirstChild("Fruits")~=nil
			local w=getW(model); local fc=getFruitCount(model)
			local data={}

			if ESP.highlightStyle=="outline" or ESP.highlightStyle=="both" then
				local sel=Instance.new("SelectionBox",espFolder)
				sel.Adornee=model; sel.Color3=espColor; sel.LineThickness=0.05
				sel.SurfaceTransparency=ESP.highlightStyle=="both" and 0.72 or 1
				sel.SurfaceColor3=espColor; data.selBox=sel
			end

			if ESP.highlightStyle=="fill" or ESP.highlightStyle=="both" or ESP.chams then
				local hl=Instance.new("Highlight",espFolder)
				hl.Adornee=model; hl.FillColor=espColor
				hl.FillTransparency=ESP.highlightStyle=="fill" and 0.6 or 0.78
				hl.OutlineColor=espColor
				hl.OutlineTransparency=ESP.highlightStyle=="fill" and 1 or 0.2
				if ESP.chams then
					pcall(function() hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop end)
				end
				data.hl=hl
			end

			if ESP.billboards then
				data.bb=makeESPBillboard(model,espColor,model.Name,w,muts,isMulti,fc)
			end
			espObjects[model]=data

			-- Fruits of multi-harvest
			if isMulti then
				local fruits=model:FindFirstChild("Fruits")
				if fruits then
					for _, fruit in ipairs(fruits:GetChildren()) do
						if espObjects[fruit] then continue end
						local fm=getMutations(fruit); local fc2=getESPColor(fruit,fm)
						local fd={}
						if ESP.highlightStyle=="outline" or ESP.highlightStyle=="both" then
							local sel2=Instance.new("SelectionBox",espFolder)
							sel2.Adornee=fruit; sel2.Color3=fc2; sel2.LineThickness=0.04
							sel2.SurfaceTransparency=1; fd.selBox=sel2
						end
						if (ESP.highlightStyle=="fill" or ESP.highlightStyle=="both") or ESP.chams then
							local hl2=Instance.new("Highlight",espFolder)
							hl2.Adornee=fruit; hl2.FillColor=fc2; hl2.FillTransparency=0.72
							hl2.OutlineColor=fc2; hl2.OutlineTransparency=0.2
							if ESP.chams then pcall(function() hl2.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop end) end
							fd.hl=hl2
						end
						if ESP.billboards then
							fd.bb=makeESPBillboard(fruit,fc2,fruit.Name,getW(fruit),fm,false,0)
						end
						espObjects[fruit]=fd
					end
				end
			end
		end
	end
end

