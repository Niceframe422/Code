Players.PlayerRemoving:Connect(function() task.wait(0.5); refreshPlayers() end)
refreshPlayers()

do
	local farm=getFarmForPlayer(player)
	stateRef.currentPlantsFolder=farm and farm:FindFirstChild("Plants_Physical") or nil
	renderPlants(); tw(myS,{Color=C.strokeHi})
