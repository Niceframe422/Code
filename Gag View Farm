------------------------------------------------
-- MAIN LOOP  (light polling, no lag)
------------------------------------------------
local lastPlayer = nil
local lastCount  = -1

while task.wait(2.5) do
	-- Refresh sub-labels for all visible player buttons
	for plr, _ in pairs(plrBtnData) do
		refreshPlrSubLabel(plr)
	end

	local plr = state.selectedPlayer
	if not plr then continue end
	local farm = getFarm(plr)
	local pf   = farm and farm:FindFirstChild("Plants_Physical")
	local count = pf and #pf:GetChildren() or 0

	if plr ~= lastPlayer or count ~= lastCount then
		lastPlayer = plr
		lastCount  = count
		state.currentPlantsFolder = pf
		if state.view == "plants" then
			renderPlants()
		end
	end
end
