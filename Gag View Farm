local function clearScroll()
	mainScroll.CanvasPosition=Vector2.new(0,0)
	for _,v in ipairs(mainScroll:GetChildren()) do
		if not v:IsA("UIListLayout") and not v:IsA("UIPadding") then v:Destroy() end
	end
end

local function sortModels(models)
	if sortMode=="name_az" then table.sort(models,function(a,b)return a.Name<b.Name end)
	elseif sortMode=="name_za" then table.sort(models,function(a,b)return a.Name>b.Name end)
	elseif sortMode=="weight_desc" then table.sort(models,function(a,b)return getW(a)>getW(b) end)
	elseif sortMode=="weight_asc" then table.sort(models,function(a,b)return getW(a)<getW(b) end)
	elseif sortMode=="mutations_desc" then table.sort(models,function(a,b)return #getMutations(a)>#getMutations(b) end)
	elseif sortMode=="fruit_desc" then table.sort(models,function(a,b)return getFruitCount(a)>getFruitCount(b) end)
	elseif sortMode=="age_desc" then table.sort(models,function(a,b)return getAge(a)>getAge(b) end)
	end
end

local function makePills(parent, mutations)
	local frame=Instance.new("Frame",parent)
	frame.BackgroundTransparency=1; frame.Size=UDim2.new(1,0,0,0)
	frame.AutomaticSize=Enum.AutomaticSize.Y
	local pl=Instance.new("UIListLayout",frame)
	pl.FillDirection=Enum.FillDirection.Horizontal; pl.Wraps=true; pl.Padding=UDim.new(0,4)
	for _,m in ipairs(mutations) do
		local mbg, mtx=getMutColor(m)
		local pill=Instance.new("TextLabel",frame)
		pill.AutomaticSize=Enum.AutomaticSize.X; pill.Size=UDim2.new(0,0,0,18)
		pill.BackgroundColor3=mbg; pill.TextColor3=mtx
		pill.Font=Enum.Font.GothamBold; pill.TextSize=9; pill.Text=" "..m.." "
		pill.BorderSizePixel=0; corner(pill,9)
	end
	return frame
end

local function emptyLbl(text)
	local L=lbl(mainScroll,{text=text,size=13,color=C.textMuted,sz=UDim2.new(1,0,0,40),xa=Enum.TextXAlignment.Center})
