------------------------------------------------
-- UTILITIES
------------------------------------------------
local function tween(obj, props)
	TweenService:Create(obj, TWEEN_INFO, props):Play()
end

local function clamp(v, lo, hi) return math.max(lo, math.min(hi, v)) end

local function uiCorner(parent, radius)
	local c = Instance.new("UICorner", parent)
	c.CornerRadius = UDim.new(0, radius or 10)
	return c
end

local function uiStroke(parent, color, thickness)
	local s = Instance.new("UIStroke", parent)
	s.Color = color or COLORS.stroke
	s.Thickness = thickness or 1
	return s
end

local function makeLabel(parent, props)
	local lbl = Instance.new("TextLabel", parent)
	lbl.BackgroundTransparency = 1
	lbl.BorderSizePixel = 0
	lbl.Font = props.font or Enum.Font.Gotham
	lbl.TextSize = props.size or 13
	lbl.TextColor3 = props.color or COLORS.textPrimary
	lbl.Text = props.text or ""
	lbl.Size = props.sz or UDim2.new(1, 0, 0, 20)
	lbl.Position = props.pos or UDim2.new(0, 0, 0, 0)
	lbl.TextXAlignment = props.align or Enum.TextXAlignment.Left
	lbl.TextYAlignment = props.valign or Enum.TextYAlignment.Center
	lbl.TextTruncate = props.truncate or Enum.TextTruncate.None
	return lbl
end

local function getMutations(model)
	local mutations = {}
	local ok, attrs = pcall(function() return model:GetAttributes() end)
	if not ok then return mutations end
	for name, value in pairs(attrs) do
		if type(value) == "boolean" and not EXCLUDED_ATTRS[name] then
			table.insert(mutations, name)
		end
	end
	table.sort(mutations)
	return mutations
end

local function getFarm(plr)
	local farmFolder = workspace:FindFirstChild("Farm")
	if not farmFolder then return nil end
	for _, farm in pairs(farmFolder:GetChildren()) do
		local imp  = farm:FindFirstChild("Important")
		local data = imp and imp:FindFirstChild("Data")
		local own  = data and data:FindFirstChild("Owner")
		if own and (own.Value == plr.UserId or own.Value == plr.Name) then
			return imp
		end
	end
	return nil
end

local function getInitials(name)
	return string.upper(string.sub(name, 1, 2))
end

local function debounce(fn, delay)
	local thread
	return function(...)
		local args = {...}
		if thread then task.cancel(thread) end
		thread = task.delay(delay, function()
			fn(table.unpack(args))
		end)
	end
end

