local function getMutColor(name)
	local mc=MUT_COLORS[name]
	if mc then return mc.bg, mc.tx end
	-- Hash fallback for unknown mutations
	local h=0; for i=1,#name do h=(h*31+string.byte(name,i))%360 end
	local r=Color3.fromHSV(h/360, 0.65, 0.55)
	local t=Color3.fromHSV(h/360, 0.45, 1.00)
	return r, t
end

