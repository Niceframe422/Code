function renderPlants()
	clearScroll()
	setControlsVisible(true)   -- [ADDED]
	backBtn.Visible = false
	local plr = state.selectedPlayer
	breadcrumb.Text = plr.Name.."'s Farm"
	headerSub.Text = "Viewing "..plr.Name.."'s plants"

	local plantsFolder = state.currentPlantsFolder
	if not plantsFolder then
		local lbl = Instance.new("TextLabel", mainScroll)
		lbl.Size = UDim2.new(1, 0, 0, 36)
		lbl.BackgroundTransparency = 1
		lbl.TextColor3 = Color3.fromRGB(90, 85, 130)
		lbl.Font = Enum.Font.Gotham
		lbl.TextSize = 13
		lbl.Text = "No Plants_Physical folder found."
		return
	end

	-- [ADDED] Filter by search text
	local query = string.lower(searchBar.Text)
	local models = {}
	for _, v in pairs(plantsFolder:GetChildren()) do
		if v:IsA("Model") then
			if query == "" or string.find(string.lower(v.Name), query, 1, true) then
				table.insert(models, v)
			end
		end
	end

	sortModels(models)  -- [ADDED]

	if #models == 0 then
		local lbl = Instance.new("TextLabel", mainScroll)
		lbl.Size = UDim2.new(1, 0, 0, 36)
		lbl.BackgroundTransparency = 1
		lbl.TextColor3 = Color3.fromRGB(90, 85, 130)
		lbl.Font = Enum.Font.Gotham
		lbl.TextSize = 13
		lbl.Text = query ~= "" and 'No plants matching "'..query..'".' or "No plants found."
		return
	end

	-- [ADDED] Result count label
	local countLbl = Instance.new("TextLabel", mainScroll)
	countLbl.Size = UDim2.new(1, 0, 0, 16)
	countLbl.BackgroundTransparency = 1
	countLbl.TextXAlignment = Enum.TextXAlignment.Left
	countLbl.Font = Enum.Font.GothamBold
	countLbl.TextSize = 10
	countLbl.TextColor3 = Color3.fromRGB(80, 75, 120)
	countLbl.Text = "  "..#models.." PLANT"..(#models ~= 1 and "S" or "")

	for _, model in ipairs(models) do
		local fruitsFolder = model:FindFirstChild("Fruits")
		local isMulti = fruitsFolder ~= nil
		local mutations = {}
		local variant, weight

		if not isMulti then
			variant = model:FindFirstChild("Variant")
			weight = model:FindFirstChild("Weight")
			mutations = getMutations(model)
		end

		local fruitCount = isMulti and #fruitsFolder:GetChildren() or 0

