renderDetail = function()
	clearScroll(); setControls(false); backBtn.Visible=true; statLbl.Text=""
	local fm=state.fruitModel; local pn=state.plantModel and state.plantModel.Name or "?"
	breadcrumb.Text=pn.." / "..fm.Name
	local muts=getMutations(fm); local weight=fm:FindFirstChild("Weight"); local variant=getVariant(fm)
	local ok,attrs=pcall(function() return fm:GetAttributes() end)
	local card=Instance.new("Frame",mainScroll); card.Size=UDim2.new(1,-2,0,0); card.AutomaticSize=Enum.AutomaticSize.Y
	card.BackgroundColor3=C.card; card.BorderSizePixel=0; corner(card,10); mkStroke(card,C.stroke)
	pad(card,14,14,14,14); vlist(card,10)
	lbl(card,{text=fm.Name,font=Enum.Font.GothamBold,size=16,color=C.textGreen,sz=UDim2.new(1,0,0,22)})
	if variant then
		local vRow=Instance.new("Frame",card); vRow.Size=UDim2.new(1,0,0,0); vRow.AutomaticSize=Enum.AutomaticSize.Y
		vRow.BackgroundTransparency=1; vRow.BorderSizePixel=0; hlist(vRow,4)
		makeVariantBadge(vRow,variant)
	end
	local function div() local d=Instance.new("Frame",card); d.Size=UDim2.new(1,0,0,1); d.BackgroundColor3=Color3.fromRGB(32,30,52); d.BorderSizePixel=0 end
	local function secH(t) lbl(card,{text=t,size=9,color=C.textSub,font=Enum.Font.GothamBold,sz=UDim2.new(1,0,0,14)}) end
	local function fieldRow(lv,val,vc)
		local row=Instance.new("Frame",card); row.Size=UDim2.new(1,0,0,28)
		row.BackgroundColor3=Color3.fromRGB(20,19,34); row.BorderSizePixel=0; corner(row,6)
		lbl(row,{text=lv,size=12,color=C.textSub,sz=UDim2.new(0.42,0,1,0),pos=UDim2.new(0,10,0,0)})
		lbl(row,{text=tostring(val),font=Enum.Font.GothamBold,size=12,color=vc or C.text,sz=UDim2.new(0.54,0,1,0),pos=UDim2.new(0.44,0,0,0)})
	end
	div(); secH("PROPERTIES")
	if variant then fieldRow("Variant",variant,Color3.fromRGB(145,205,255)) end
	if weight then fieldRow("Weight",string.format("%.4f",weight.Value),C.textAmber) end
	if ok then
		local ex={}
		for k,v in pairs(attrs) do
			if type(v)~="boolean" and k~="Weight" and k~="Variant" and not EXCL[k] then table.insert(ex,{name=k,value=v}) end
		end
		table.sort(ex,function(a,b) return a.name<b.name end)
		for _,e in ipairs(ex) do fieldRow(e.name,tostring(e.value)) end
	end
	div(); secH("MUTATIONS ("..#muts..")  ·  Total ×"..mutTotalMult(muts))
	if #muts==0 then lbl(card,{text="None detected",size=13,color=C.textDim,sz=UDim2.new(1,0,0,20)})
	else makePills(card,muts,true) end
end

