local function getESPColor(model, muts)
	if ESP.colorMode=="mutation" then
		return #muts>0 and Color3.fromRGB(210,65,250) or Color3.fromRGB(96,88,185)
	elseif ESP.colorMode=="rarity" then
		local n=#muts
		if n==0 then return Color3.fromRGB(110,110,155)
		elseif n==1 then return Color3.fromRGB(65,165,255)
		elseif n==2 then return Color3.fromRGB(165,65,255)
		else return Color3.fromRGB(255,95,28) end
	else
		if model.Parent and model.Parent.Name=="Fruits" then return Color3.fromRGB(255,178,42) end
		if model:FindFirstChild("Fruits") then return Color3.fromRGB(58,208,126) end
		return Color3.fromRGB(96,88,200)
	end
end

local function makePrimary(m)
	if m:IsA("Model") then return m.PrimaryPart or m:FindFirstChildWhichIsA("BasePart")
	elseif m:IsA("BasePart") then return m end
end

local function makeBillboard(model, col, name, w, muts, isMulti, fc, variant)
	local part=makePrimary(model); if not part then return nil end
	local compact=ESP.detail=="compact"
	local bb=Instance.new("BillboardGui",part)
	bb.AlwaysOnTop=true
	bb.Size=UDim2.new(0,compact and 148 or 200, 0, compact and 52 or 100)
	bb.StudsOffset=Vector3.new(0,5.5,0); bb.MaxDistance=175

	local fr=Instance.new("Frame",bb); fr.Size=UDim2.new(1,0,1,0)
	fr.BackgroundColor3=Color3.fromRGB(8,8,16); fr.BackgroundTransparency=0.08; fr.BorderSizePixel=0; corner(fr,10)
	mkStroke(fr,col,1.8)
	local ab=Instance.new("Frame",fr); ab.Size=UDim2.new(1,-12,0,2); ab.Position=UDim2.new(0,6,0,4)
	ab.BackgroundColor3=col; ab.BorderSizePixel=0; corner(ab,1)
	pad(fr,8,8,13,5); vlist(fr,3)

	local nm=Instance.new("TextLabel",fr); nm.Size=UDim2.new(1,0,0,15); nm.BackgroundTransparency=1
	nm.Font=Enum.Font.GothamBold; nm.TextSize=11
	nm.TextColor3=isMulti and C.textGreen or C.text; nm.Text=name
	nm.TextXAlignment=Enum.TextXAlignment.Left; nm.TextTruncate=Enum.TextTruncate.AtEnd

	if not compact then
		if variant then
			local vCfg=VARIANT_CFG[variant]
			local vl=Instance.new("TextLabel",fr); vl.Size=UDim2.new(1,0,0,11); vl.BackgroundTransparency=1
			vl.Font=Enum.Font.GothamBold; vl.TextSize=9
			vl.TextColor3=vCfg and vCfg.tx or Color3.fromRGB(145,205,255)
			vl.Text=vCfg and vCfg.label or ("◈ "..variant)
			vl.TextXAlignment=Enum.TextXAlignment.Left
		end
		local wl=Instance.new("TextLabel",fr); wl.Size=UDim2.new(1,0,0,11); wl.BackgroundTransparency=1
		wl.Font=Enum.Font.Gotham; wl.TextSize=10; wl.TextColor3=C.textAmber
		wl.Text="⚖ "..string.format("%.3f",w)..(isMulti and "   🍃 "..fc.."f" or "")
		wl.TextXAlignment=Enum.TextXAlignment.Left
		if #muts>0 then
			local tm=mutTotalMult(muts)
			local ml=Instance.new("TextLabel",fr); ml.Size=UDim2.new(1,0,0,11); ml.BackgroundTransparency=1
			ml.Font=Enum.Font.Gotham; ml.TextSize=10
			local _,tx1=getMutBadgeColors(muts[1])
			ml.TextColor3=tx1
			local preview=(muts[1])..(muts[2] and " · "..(muts[2]) or "")..(#muts>2 and " +"..( #muts-2) or "")
			ml.Text="✦ "..preview.." (×"..tm..")"
			ml.TextXAlignment=Enum.TextXAlignment.Left; ml.TextTruncate=Enum.TextTruncate.AtEnd
		else
			local nl=Instance.new("TextLabel",fr); nl.Size=UDim2.new(1,0,0,11); nl.BackgroundTransparency=1
			nl.Font=Enum.Font.Gotham; nl.TextSize=10; nl.TextColor3=C.textDim
			nl.Text="◦ No mutations"; nl.TextXAlignment=Enum.TextXAlignment.Left
		end
	else
		local cl=Instance.new("TextLabel",fr); cl.Size=UDim2.new(1,0,0,11); cl.BackgroundTransparency=1
		cl.Font=Enum.Font.Gotham; cl.TextSize=10; cl.TextColor3=C.textSub
		cl.Text="⚖"..string.format("%.2f",w).."  ✦"..(#muts).."  ×"..mutTotalMult(muts)
		cl.TextXAlignment=Enum.TextXAlignment.Left
	end
	return bb
end

local function clearESP()
	for _,d in pairs(espObjects) do
		if d.hl  then pcall(function() d.hl:Destroy() end) end
		if d.sel then pcall(function() d.sel:Destroy() end) end
		if d.bb  then pcall(function() d.bb:Destroy() end) end
	end
	espObjects={}
end

local function applyToModel(model, col, isMulti, variant)
	if espObjects[model] then return end
	local muts=getMutations(model); local w=getW(model); local fc=getFruitCount(model)
	local d={}

	if ESP.style=="fill" or ESP.style=="both" or ESP.chams then
		local hl=Instance.new("Highlight",espFolder)
		hl.Adornee=model
		hl.FillColor=col
		hl.FillTransparency=ESP.style=="outline" and 1 or (ESP.style=="both" and 0.75 or 0.6)
		hl.OutlineColor=col
		hl.OutlineTransparency=ESP.style=="fill" and 1 or 0.1
		if ESP.chams then pcall(function() hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop end) end
		d.hl=hl
	end

	if ESP.style=="outline" then
		local sel=Instance.new("SelectionBox",espFolder)
		sel.Adornee=model; sel.Color3=col; sel.LineThickness=0.06
		sel.SurfaceTransparency=1; sel.SurfaceColor3=col; d.sel=sel
	end

	if ESP.billboards then
		d.bb=makeBillboard(model,col,model.Name,w,muts,isMulti,fc,variant)
	end
	espObjects[model]=d
end

-- NOW define refreshESP (the upvalue used in MISC toggles)
refreshESP = function()
	clearESP(); if not ESP.enabled then return end
	for _,fd in ipairs(getAllFarms()) do
		local ownPlr=fd.player
		if ownPlr and ESP.blocked[ownPlr.UserId] then continue end
		local pf=fd.imp and fd.imp:FindFirstChild("Plants_Physical")
		if not pf then continue end
		for _,model in ipairs(pf:GetChildren()) do
			if not model:IsA("Model") then continue end
			local muts=getMutations(model); local col=getESPColor(model,muts)
			local isMulti=model:FindFirstChild("Fruits")~=nil
			local variant=getVariant(model)
			applyToModel(model,col,isMulti,variant)
			if isMulti then
				local ff=model:FindFirstChild("Fruits")
				if ff then
					for _,fruit in ipairs(ff:GetChildren()) do
						if not fruit:IsA("Model") then continue end
						local fm=getMutations(fruit); local fc=getESPColor(fruit,fm)
						applyToModel(fruit,fc,false,getVariant(fruit))
					end
				end
			end
		end
	end
end

