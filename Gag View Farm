			local preview=muts[1]..(muts[2] and " · "..muts[2] or "")..(#muts>2 and " +"..( #muts-2) or "")
			ml.Text="✦ "..preview.." (×"..tm..")"; ml.TextXAlignment=Enum.TextXAlignment.Left; ml.TextTruncate=Enum.TextTruncate.AtEnd
