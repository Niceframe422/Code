-- ── Data helpers ──────────────────────────────────
local function getMutations(model)
	local out={}
	local ok,attrs=pcall(function() return model:GetAttributes() end)
	if not ok then return out end
	for n,v in pairs(attrs) do
		if type(v)=="boolean" and not EXCL[n] then table.insert(out,n) end
	end
	table.sort(out,function(a,b)
		local ma=getMutInfo(a).mult; local mb=getMutInfo(b).mult
		return ma>mb
	end)
	return out
end
local function getW(m) local w=m:FindFirstChild("Weight"); return w and w.Value or 0 end
local function getVariant(m) local v=m:FindFirstChild("Variant"); return v and tostring(v.Value) or nil end
local function getFruits(m) local f=m:FindFirstChild("Fruits"); return f end
local function getFruitCount(m) local f=getFruits(m); return f and #f:GetChildren() or 0 end
local function getAge(m) local a=m:FindFirstChild("Age") or m:FindFirstChild("GrowTime"); return a and a.Value or 0 end
local function initials(n) return string.upper(string.sub(n,1,2)) end

local function isValidPlant(inst)
	if not inst:IsA("Model") then return false end
	return inst.Parent and inst.Parent.Name=="Plants_Physical"
end
local function isValidFruit(inst)
	if not inst:IsA("Model") then return false end
	local fruitsFolder=inst.Parent
	if not (fruitsFolder and fruitsFolder.Name=="Fruits") then return false end
	return isValidPlant(fruitsFolder.Parent)
end

local function mutTotalMult(muts)
	local s=0; for _,m in ipairs(muts) do s=s+getMutInfo(m).mult end; return s
end

-- ── Farm finders ──────────────────────────────────
local function getAllFarms()
	local F=workspace:FindFirstChild("Farm"); if not F then return {} end
	local out={}
	for _,farm in pairs(F:GetChildren()) do
		local imp=farm:FindFirstChild("Important")
		local data=imp and imp:FindFirstChild("Data")
		local own=data and data:FindFirstChild("Owner")
		if own then
			local uid=tonumber(own.Value)
			local plr=nil
			for _,p in ipairs(Players:GetPlayers()) do
				if p.UserId==uid or p.Name==tostring(own.Value) then plr=p;break end
			end
			table.insert(out,{imp=imp, owner=own.Value, player=plr})
		end
	end
	return out
end
local function getFarmFor(plr)
	local F=workspace:FindFirstChild("Farm"); if not F then return nil end
	for _,farm in pairs(F:GetChildren()) do
		local imp=farm:FindFirstChild("Important")
		local data=imp and imp:FindFirstChild("Data")
		local own=data and data:FindFirstChild("Owner")
		if own and (own.Value==plr.UserId or own.Value==plr.Name) then return imp end
	end
end

local function debounce(fn,d)
	local t
	return function(...)
		local a={...}; if t then task.cancel(t) end
		t=task.delay(d,function() fn(table.unpack(a)) end)
	end
end

