--  WORLD HOVER  (RenderStepped — minimal allocs)
-- ════════════════════════════════════════════════════
local lastHoverModel=nil
local ownerCache={}

local function rebuildOwnerCache()
	local newCache={}
	for _,fd in ipairs(getAllFarms()) do
		local pf=fd.imp and fd.imp:FindFirstChild("Plants_Physical"); if not pf then continue end
		local ownerName=fd.player and fd.player.Name or tostring(fd.owner)
		for _,m in ipairs(pf:GetChildren()) do
			if m:IsA("Model") then
				newCache[m]=ownerName
				local ff=m:FindFirstChild("Fruits")
				if ff then for _,fruit in ipairs(ff:GetChildren()) do if fruit:IsA("Model") then newCache[fruit]=ownerName end end end
			end
		end
	end
	ownerCache=newCache
end
rebuildOwnerCache()

local function isBlockedOwner(ownerName)
	if not ownerName then return false end
	for _,plr in ipairs(Players:GetPlayers()) do
		if plr.Name==ownerName and ESP.blocked[plr.UserId] then return true end
	end
	return false
end

RunService.RenderStepped:Connect(function()
	if not ESP.hover then
		if hoverPopup.Visible then hoverPopup.Visible=false; lastHoverModel=nil end; return
	end
	local target=mouse.Target; local model=target
	if model then
		if model:IsA("BasePart") then model=model.Parent end
		if not (model and model:IsA("Model")) then model=nil end
	end
	local ownerName=model and ownerCache[model]
	if not ownerName or isBlockedOwner(ownerName) then
		if hoverPopup.Visible then hoverPopup.Visible=false; lastHoverModel=nil end; return
	end
	local mp=UIS:GetMouseLocation(); local vp=camera.ViewportSize
	hoverPopup.Position=UDim2.new(0,math.min(mp.X+22,vp.X-260),0,math.min(mp.Y+22,vp.Y-220))
	if model==lastHoverModel then hoverPopup.Visible=true; return end
	lastHoverModel=model
	local muts=getMutations(model); local w=getW(model); local variant=getVariant(model)
	local isFruit=model.Parent and model.Parent.Name=="Fruits"
	local isMulti=not isFruit and model:FindFirstChild("Fruits")~=nil
	local fc=isMulti and getFruitCount(model) or 0
	local col=getESPColor(model,muts)
	hpAccent.BackgroundColor3=col
	hpTitle.Text=model.Name
	hpTitle.TextColor3=isFruit and C.textAmber or (isMulti and C.textGreen or C.text)
	if isFruit then hpTypeBadge.Text=" 🍎 Fruit "; hpTypeBadge.BackgroundColor3=Color3.fromRGB(46,26,10); hpTypeBadge.TextColor3=C.textAmber
	elseif isMulti then hpTypeBadge.Text=" ⬥ Multi · "..fc.."f "; hpTypeBadge.BackgroundColor3=Color3.fromRGB(12,44,28); hpTypeBadge.TextColor3=C.textGreen
	else hpTypeBadge.Text=" ◆ Single "; hpTypeBadge.BackgroundColor3=Color3.fromRGB(28,24,56); hpTypeBadge.TextColor3=Color3.fromRGB(140,132,220) end
	hpOwnerBadge.Text=" 👤 "..ownerName.." "
	local vCfg=variant and VARIANT_CFG[variant]
	if vCfg then
		hpVariantSpecial.Text=" "..vCfg.label.." "; hpVariantSpecial.BackgroundColor3=vCfg.bg; hpVariantSpecial.TextColor3=vCfg.tx
		hpVariantSpecial.Visible=true
	else hpVariantSpecial.Visible=false end
	hpWVal.Text=w>0 and string.format("%.4f",w) or "—"
	hpVVal.Text=variant or "—"
	local tm=mutTotalMult(muts)
	hpMultVal.Text=tm>0 and ("×"..tm) or "—"
	hpFruitRow.Visible=isMulti; if isMulti then hpFLbl.Text="🍃 "..fc.." fruit"..(fc~=1 and "s" or "") end
	hpMutHdrL.Text="MUTATIONS ("..#muts..")"
	rebuildHpMuts(muts)
	hoverPopup.Visible=true
end)

-- ════════════════════════════════════════════════════
--  MAIN LOOP  (non-blocking via task.spawn)
-- ════════════════════════════════════════════════════
task.spawn(function()
	local lastPlr=nil; local lastCount=-1
	while task.wait(ESP.rate) do
		if not gui or not gui.Parent then break end  -- bail if gui destroyed
		rebuildOwnerCache()
		for plr in pairs(plrData) do
			if plr and plr.Parent then refreshSub(plr) end
		end
		local plr=state.selectedPlayer
		if not plr or not plr.Parent then continue end
		local farm=getFarmFor(plr); local pf=farm and farm:FindFirstChild("Plants_Physical")
		local c=pf and #pf:GetChildren() or 0
		if plr~=lastPlr or c~=lastCount then
			lastPlr=plr; lastCount=c; state.plantsFolder=pf
			if state.view=="plants" then renderPlants() end
			if ESP.enabled then refreshESP() end
		end
	end
end)
