		local card,s=makeCard(mainScroll,true)
		local row1=Instance.new("Frame",card); row1.Size=UDim2.new(1,0,0,20); row1.BackgroundTransparency=1
		lbl(row1,{text=fm.Name,font=Enum.Font.GothamBold,size=14,color=C.textGreen,sz=UDim2.new(0.6,0,1,0),trunc=Enum.TextTruncate.AtEnd})
