	local pm=state.plantModel
	if not pm or not pm.Parent then renderPlants(); return end
	local isMine=(state.selectedPlayer==player)
	breadcrumb.Text=pm.Name.." / Fruits"
	local ff=pm:FindFirstChild("Fruits"); if not ff then emptyMsg("No Fruits."); statLbl.Text=""; return end
	local q=string.lower(searchBox.Text); local fruits={}
	for _,v in ipairs(ff:GetChildren()) do
		if v:IsA("Model") and (q=="" or string.find(string.lower(v.Name),q,1,true)) then
			if not mutOnly or #getMutations(v)>0 then table.insert(fruits,v) end
		end
	end
	sortModels(fruits)
	local tm=0; for _,f in ipairs(fruits) do tm=tm+#getMutations(f) end
	statLbl.Text=#fruits.." fruits  ·  "..tm.." mutations"
	lbl(mainScroll,{text="  "..#fruits.." FRUIT"..(#fruits~=1 and "S" or "").." — "..string.upper(pm.Name),size=9,color=C.textDim,font=Enum.Font.GothamBold,sz=UDim2.new(1,0,0,16)})
