	if not dragging then return end
	if inp.UserInputType~=Enum.UserInputType.MouseMovement and inp.UserInputType~=Enum.UserInputType.Touch then return end
	local d=inp.Position-dragStart; local vp=camera.ViewportSize; local sc=uiScale.Scale
	main.Position=UDim2.new(0,clamp(startPos.X.Offset+d.X,0,vp.X-main.Size.X.Offset*sc),
		0,clamp(startPos.Y.Offset+d.Y,0,vp.Y-main.Size.Y.Offset*sc))
end)
UIS.InputEnded:Connect(function(inp)
	if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then dragging=false end
end)

