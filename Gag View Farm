function renderFruits()
	clearScroll()
	setControlsVisible(true)   -- [ADDED]
	backBtn.Visible = true
	local plantModel = state.currentPlantModel
	breadcrumb.Text = plantModel.Name.."  /  Fruits"

	local fruitsFolder = plantModel:FindFirstChild("Fruits")
	if not fruitsFolder then
		local lbl = Instance.new("TextLabel", mainScroll)
		lbl.Size = UDim2.new(1, 0, 0, 36)
		lbl.BackgroundTransparency = 1
		lbl.TextColor3 = Color3.fromRGB(90, 85, 130)
		lbl.Font = Enum.Font.Gotham
		lbl.TextSize = 13
		lbl.Text = "No Fruits folder found."
		return
	end

	-- [ADDED] Filter by search text
	local query = string.lower(searchBar.Text)
	local fruits = {}
	for _, v in pairs(fruitsFolder:GetChildren()) do
		if query == "" or string.find(string.lower(v.Name), query, 1, true) then
			table.insert(fruits, v)
		end
	end

	sortModels(fruits)  -- [ADDED]

	-- Section header with live count
	local sectionLbl = Instance.new("TextLabel", mainScroll)
	sectionLbl.Size = UDim2.new(1, 0, 0, 20)
	sectionLbl.BackgroundTransparency = 1
	sectionLbl.TextXAlignment = Enum.TextXAlignment.Left
	sectionLbl.Font = Enum.Font.GothamBold
	sectionLbl.TextSize = 10
	sectionLbl.TextColor3 = Color3.fromRGB(90, 85, 130)
	sectionLbl.Text = "  "..#fruits.." FRUIT"..(#fruits ~= 1 and "S" or "").." IN "..string.upper(plantModel.Name)
		..(query ~= "" and ' — filter: "'..query..'"' or "")

	if #fruits == 0 then
		local lbl = Instance.new("TextLabel", mainScroll)
		lbl.Size = UDim2.new(1, 0, 0, 36)
		lbl.BackgroundTransparency = 1
		lbl.TextColor3 = Color3.fromRGB(90, 85, 130)
		lbl.Font = Enum.Font.Gotham
		lbl.TextSize = 13
		lbl.Text = query ~= "" and 'No fruits matching "'..query..'".' or "No fruits yet."
		return
	end

	for _, fruitModel in ipairs(fruits) do
		local variant = fruitModel:FindFirstChild("Variant")
		local weight = fruitModel:FindFirstChild("Weight")
		local mutations = getMutations(fruitModel)

		local card = Instance.new("TextButton", mainScroll)
		card.Size = UDim2.new(1, 0, 0, 0)
		card.AutomaticSize = Enum.AutomaticSize.Y
		card.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
		card.BorderSizePixel = 0
		card.Text = ""
		card.AutoButtonColor = false
		Instance.new("UICorner", card).CornerRadius = UDim.new(0, 10)

		local cStroke = Instance.new("UIStroke", card)
		cStroke.Color = Color3.fromRGB(38, 72, 55)

		local cardPad = Instance.new("UIPadding", card)
		cardPad.PaddingTop = UDim.new(0, 10)
		cardPad.PaddingBottom = UDim.new(0, 10)
		cardPad.PaddingLeft = UDim.new(0, 12)
		cardPad.PaddingRight = UDim.new(0, 10)

		local cardLayout = Instance.new("UIListLayout", card)
		cardLayout.Padding = UDim.new(0, 5)

		local row1 = Instance.new("Frame", card)
		row1.Size = UDim2.new(1, 0, 0, 20)
		row1.BackgroundTransparency = 1

		local fName = Instance.new("TextLabel", row1)
		fName.Size = UDim2.new(0.7, 0, 1, 0)
		fName.BackgroundTransparency = 1
		fName.TextXAlignment = Enum.TextXAlignment.Left
		fName.Font = Enum.Font.GothamBold
		fName.TextSize = 14
		fName.TextColor3 = Color3.fromRGB(170, 225, 195)
		fName.Text = fruitModel.Name
		fName.TextTruncate = Enum.TextTruncate.AtEnd

		if #mutations > 0 then
			local mutBadge = Instance.new("TextLabel", row1)
			mutBadge.Size = UDim2.new(0, 85, 0, 18)
			mutBadge.Position = UDim2.new(1, -85, 0.5, -9)
			mutBadge.BackgroundColor3 = Color3.fromRGB(52, 36, 82)
			mutBadge.TextColor3 = Color3.fromRGB(185, 155, 255)
			mutBadge.Font = Enum.Font.GothamBold
			mutBadge.TextSize = 10
			mutBadge.Text = #mutations.." mutation"..(#mutations > 1 and "s" or "")
			mutBadge.BorderSizePixel = 0
			Instance.new("UICorner", mutBadge).CornerRadius = UDim.new(1, 0)
		end

		local parts = {}
		if variant then table.insert(parts, "Variant: "..tostring(variant.Value)) end
		if weight then table.insert(parts, "Weight: "..string.format("%.2f", weight.Value)) end
		if #parts > 0 then
			local infoLbl = Instance.new("TextLabel", card)
			infoLbl.Size = UDim2.new(1, 0, 0, 16)
			infoLbl.BackgroundTransparency = 1
			infoLbl.TextXAlignment = Enum.TextXAlignment.Left
			infoLbl.Font = Enum.Font.Gotham
			infoLbl.TextSize = 12
			infoLbl.TextColor3 = Color3.fromRGB(95, 155, 120)
			infoLbl.Text = table.concat(parts, "   ")
		end

		if #mutations > 0 then
			makeMutationPills(card, mutations)
		end

		local capturedFruit = fruitModel
		card.MouseEnter:Connect(function() cStroke.Color = Color3.fromRGB(55, 145, 90) end)
		card.MouseLeave:Connect(function() cStroke.Color = Color3.fromRGB(38, 72, 55) end)
		card.MouseButton1Click:Connect(function()
			state.view = "detail"
			state.currentFruitModel = capturedFruit
			renderDetail()
		end)
	end
end

