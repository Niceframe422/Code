		badge.Position = UDim2.new(1, -92, 0.5, -9)
		badge.BorderSizePixel = 0
		badge.Font = Enum.Font.GothamBold
		badge.TextSize = 10
		Instance.new("UICorner", badge).CornerRadius = UDim.new(1, 0)
		if isMulti then
			badge.BackgroundColor3 = Color3.fromRGB(22, 62, 42)
			badge.TextColor3 = Color3.fromRGB(75, 215, 140)
			badge.Text = "Multi-Harvest"
		else
