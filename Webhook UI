--====================================================
-- FILE I/O
--====================================================
local function fileSave(path, text)
    local ok, err = pcall(writefile, path, text)
    if not ok then warn("[Monitor] writefile:", err) end
    return ok
end

local function fileLoad(path)
    local ok, v = pcall(readfile, path)
    return (ok and type(v) == "string" and #v > 0) and v or nil
end

local function fileExists(path)
    if isfile then
        local ok, v = pcall(isfile, path)
        if ok then return v end
    end
    local ok, v = pcall(readfile, path)
    return ok and type(v) == "string" and #v > 0
end

local function fileDel(path)
    if delfile then pcall(delfile, path) end
end

-- Load saved webhooks from JSON file
local function loadWebhooks()
    local raw = fileLoad(Config.SaveFile)
    if not raw then return end
    local ok, tbl = pcall(HttpService.JSONDecode, HttpService, raw)
    if ok and type(tbl) == "table" then
        for k, v in pairs(tbl) do
            if Config.Webhooks[k] ~= nil then
                Config.Webhooks[k] = v
            end
        end
    end
end

local function saveWebhooks()
    local ok, json = pcall(HttpService.JSONEncode, HttpService, Config.Webhooks)
    if ok then fileSave(Config.SaveFile, json) end
end

--====================================================
-- UTILITIES
--====================================================
local function utcNow()
    local t = os.date("!*t", os.time())
    return ("%d-%02d-%02dT%02d:%02d:%02dZ"):format(t.year, t.month, t.day, t.hour, t.min, t.sec)
end

local function timeStr()
    local t = os.date("!*t", os.time())
    return ("%02d:%02d:%02d"):format(t.hour, t.min, t.sec)
end

local function getPing()
    local ok, p = pcall(function()
        return math.round(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
    end)
    return ok and p or 0
end

local function getPlayerCount() return #Players:GetPlayers() end

local _gameName = nil
local function getGameName()
    if _gameName then return _gameName end
    local ok, info = pcall(function()
        return MarketplaceService:GetProductInfo(game.PlaceId)
    end)
    _gameName = (ok and info and info.Name) and info.Name or tostring(game.PlaceId)
    return _gameName
end

local function getRequest()
    return (syn and syn.request)
        or (http and http.request)
        or (fluxus and fluxus.request)
        or http_request
        or request
end

--====================================================
-- LOG BUFFER
--====================================================
local LogBuffer = {}
local LogCBs    = {}

local function logAdd(kind, msg)
    local e = { kind = kind, msg = msg, ts = timeStr() }
    table.insert(LogBuffer, 1, e)
    if #LogBuffer > 100 then table.remove(LogBuffer) end
    for _, cb in ipairs(LogCBs) do pcall(cb, e) end
end

local function onLog(cb) table.insert(LogCBs, cb) end

--====================================================
-- SEND ENGINE
--====================================================
local embedsSent  = 0
local sendErrors  = 0

-- Build common embed fields
local function field(n, v, i)
    return { name = n, value = tostring(v), inline = i == true }
end

local function commonFields(extra)
    local f = {}
    if Config.Embed.IncludeGameName    then table.insert(f, field("Game",    getGameName(),      true)) end
    if Config.Embed.IncludePlayerCount then table.insert(f, field("Players", getPlayerCount(),   true)) end
    if Config.Embed.IncludePing        then table.insert(f, field("Ping",    getPing().."ms",    true)) end
    if Config.Embed.IncludePlaceId     then table.insert(f, field("PlaceID", tostring(game.PlaceId), true)) end
    table.insert(f, field("Time", timeStr(), false))
    for _, v in ipairs(extra or {}) do table.insert(f, v) end
    return f
end

local function buildEmbed(opts)
    local e = {
        title  = opts.title  or "",
        color  = opts.color  or 0x5865F2,
        fields = opts.fields or {},
    }
    if Config.Embed.IncludeTimestamp then e.timestamp = utcNow() end
    if opts.description then e.description = opts.description end
    return e
end

-- sendTo: route embed to a specific webhook key
local function sendTo(routeKey, embed)
    local url = Config.Webhooks[routeKey] or Config.Webhooks["default"] or ""
    if url == "" then
        logAdd("warn", "no url for route '"..routeKey.."', embed dropped")
        return
    end
    local req = getRequest()
    if not req then warn("[Monitor] no http request function"); return end
    local botName = Config.BotNames[routeKey] or Config.BotNames["default"] or "Monitor"
    local ok, err = pcall(function()
        req({
            Url     = url,
            Method  = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body    = HttpService:JSONEncode({
                username = botName,
                embeds   = { embed },
            })
        })
    end)
    if ok then
        embedsSent = embedsSent + 1
        logAdd("info", "["..routeKey.."] "..tostring(embed.title or "embed"))
    else
        sendErrors = sendErrors + 1
        logAdd("err", "send failed ["..routeKey.."]: "..tostring(err))
    end
end

-- Convenience: send to default route
local function send(embed)
    sendTo("default", embed)
end

--====================================================
-- STATUS TRACKER MODULE
--====================================================
local StatusTracker = {}
do
    local state = {}
    for _, f in ipairs(Config.StatusFields) do
        state[f.key] = f.default
    end

    -- Get current value
    function StatusTracker.get(key)
        return state[key]
    end

    -- Set value; fires webhook if configured
    function StatusTracker.set(key, value)
        local old = state[key]
        if old == value then return end
        state[key] = value
        logAdd("info", "status ["..key.."]: "..tostring(old).." → "..tostring(value))

        -- fire change callbacks (for UI)
        for _, cb in ipairs(StatusTracker._cbs or {}) do
            pcall(cb, key, value, old)
        end

        -- optionally send embed
        if Config.StatusEmbedOnChange[key] and Config.Modules.StatusTracker.enabled then
            local label = key
            for _, f in ipairs(Config.StatusFields) do
                if f.key == key then label = f.label; break end
            end
            sendTo("status", buildEmbed({
                title  = label.." Updated",
                color  = Config.Modules.StatusTracker.color,
                fields = commonFields({
                    field("Before", tostring(old),   true),
                    field("After",  tostring(value), true),
                })
            }))
        end
    end

    StatusTracker._cbs = {}
    function StatusTracker.onChange(cb)
        table.insert(StatusTracker._cbs, cb)
    end

    -- Expose state table for UI reads
    function StatusTracker.getAll()
        return state
    end
end

