    thumb.Position         = getter() and UDim2.new(1,-13,0.5,-5) or UDim2.new(0,2,0.5,-5)
    thumb.BackgroundColor3 = getter() and Theme.TEXT or Theme.DIM
    thumb.BorderSizePixel  = 0
    thumb.Parent           = track
    mkCorner(thumb, 99)

    local click = Instance.new("TextButton")
    click.Size             = UDim2.new(1,0,1,0)
    click.BackgroundTransparency = 1
    click.Text             = ""
    click.BorderSizePixel  = 0
    click.Parent           = track

    click.MouseButton1Click:Connect(function()
        setter(not getter())
        local on = getter()
        track.BackgroundColor3 = on and Theme.ACCENT or Theme.BG3
        thumb.BackgroundColor3 = on and Theme.TEXT or Theme.DIM
        thumb.Position         = on and UDim2.new(1,-13,0.5,-5) or UDim2.new(0,2,0.5,-5)
    end)
end

