    local isAFK     = false

    UserInputService.InputBegan:Connect(function()
        lastInput = tick()
        afkLastV.Text = "just now"
        if isAFK then
            isAFK = false
            afkStatV.Text       = "active"
            afkStatV.TextColor3 = GREEN
            logAdd("ok","returned from afk")
