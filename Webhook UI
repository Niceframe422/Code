    -- Walks the exact path and reports what it finds at each step.
    -- If a node is missing it lists the actual children so you can see
    -- the real name (useful when the game renamed something).
    local function runProbe()
        local sg2 = PG:FindFirstChild("TradeTokenCurrency_UI")
        if not sg2 then
            dbgSG.Text       = "NOT FOUND"
            dbgSG.TextColor3 = Theme.RED
            for _, v in ipairs({dbgTT, dbgLbl, dbgRaw, dbgNum}) do
                v.Text = "—"; v.TextColor3 = Theme.DIM
            end
            local kids = {}
            for _, c in ipairs(PG:GetChildren()) do table.insert(kids, c.Name) end
            probeResultL.Text       = "TradeTokenCurrency_UI not in PlayerGui. "
                .."All PlayerGui children: "..table.concat(kids,", ")
            probeResultL.TextColor3 = Theme.RED
            return
        end
        dbgSG.Text       = "found ("..sg2.ClassName..")"
        dbgSG.TextColor3 = Theme.GREEN

        local tt2 = sg2:FindFirstChild("TradeTokens")
        if not tt2 then
            dbgTT.Text       = "NOT FOUND"
