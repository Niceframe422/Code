    local peakPing    = 0
    local lastPingTick = 0

    RunService.Heartbeat:Connect(function()
        -- uptime
        local el = math.floor(tick() - startTick)
        uptimeV.Text = ("%02d:%02d:%02d"):format(math.floor(el/3600), math.floor((el%3600)/60), el%60)

        -- ping every 2s
        if tick() - lastPingTick >= 2 then
            lastPingTick = tick()
            local p = getPing()
            table.insert(pingBuf, p)
            if #pingBuf > 150 then table.remove(pingBuf,1) end
            peakPing = math.max(peakPing, p)
            local sum = 0; for _,v in ipairs(pingBuf) do sum=sum+v end
            local avg = math.round(sum/#pingBuf)

            pingV.Text     = p.."ms"
            pingV.TextColor3 = p<100 and GREEN or p<200 and YELLOW or RED
            pngCurV.Text   = p.."ms"
            pngCurV.TextColor3 = p<100 and GREEN or p<200 and YELLOW or RED
            pngAvgV.Text   = avg.."ms"
            pngPeakV.Text  = peakPing.."ms"
            playersV.Text  = getPlayerCount().." / "..Players.MaxPlayers
        end

        -- stats update
        sentV.Text   = tostring(embedsSent)
        logCntV.Text = tostring(#LogBuffer)
    end)

    -- game name async
    task.spawn(function() gameV.Text = getGameName() end)

    -- afk tracker lives here so it can update the label
