    brl.FillDirection       = Enum.FillDirection.Horizontal
    brl.HorizontalAlignment = Enum.HorizontalAlignment.Left
    brl.Padding             = UDim.new(0,4)

    local function mkSmallBtn(txt, bg, tc, lo)
        local b = Instance.new("TextButton")
        b.Text             = txt
        b.Size             = UDim2.new(0,70,0,22)
        b.BackgroundColor3 = bg
        b.TextColor3       = tc
        b.Font             = Enum.Font.GothamMedium
        b.TextSize         = 9
        b.BorderSizePixel  = 0
        b.AutoButtonColor  = false
        b.LayoutOrder      = lo
        b.Parent           = bRow
        mkCorner(b, 5)
        return b
