                send(buildEmbed({ title="Returned from AFK", color=0x57F287,
                    fields=commonFields({field("Player", LP.Name, true)}) }))
            end
        end
    end)

    RunService.Heartbeat:Connect(function()
        local idle = math.floor(tick() - lastInput)
        if idle > 5 then
            afkLastV.Text = idle.."s ago"
        end
        if not isAFK and idle >= Config.AFKThreshold then
            isAFK = true
            afkStatV.Text       = "afk"
            afkStatV.TextColor3 = YELLOW
            logAdd("warn","went afk ("..Config.AFKThreshold.."s idle)")
            if Config.Send.OnAFK then
                send(buildEmbed({ title="Player AFK", color=0xFEE75C,
                    fields=commonFields({field("Player",LP.Name,true),field("Idle",Config.AFKThreshold.."s",true)}) }))
            end
        end
    end)
end

