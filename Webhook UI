local function onPlayerAdded(player)
    if not Config.Send.OnJoin then return end
    local age = "unknown"
    local ok, a = pcall(function() return player:GetAccountAge() end)
    if ok then
        age = math.floor(a/365).."y "..math.floor((a%365)/30).."m"
    end
    logAdd("ok", player.Name.." joined (age: "..age..")")
    send(buildEmbed({ title="Player Joined", color=0x57F287,
        fields=commonFields({field("Player",player.Name,true),field("Age",age,true)}) }))
end

local function onPlayerRemoving(player)
    if not Config.Send.OnLeave then return end
    logAdd("err", player.Name.." left")
    send(buildEmbed({ title="Player Left", color=0xED4245,
        fields=commonFields({field("Player",player.Name,true)}) }))
end

local function setupDisconnect()
    game:BindToClose(function()
        if not Config.Send.OnDisconnect then return end
        logAdd("err","session ended")
        send(buildEmbed({ title="Session Ended", color=0xFEE75C,
            fields=commonFields({field("Player",LP.Name,true)}) }))
    end)
end

local function setupPingMonitor()
    local lastSpike = 0
    RunService.Heartbeat:Connect(function()
        if not Config.Send.OnPingSpike then return end
        if tick()-lastSpike < 60 then return end
        local p = getPing()
        if p >= Config.PingSpikeThreshold then
            lastSpike = tick()
            logAdd("warn","ping spike: "..p.."ms")
            send(buildEmbed({ title="Ping Spike", color=0xFEE75C,
                fields=commonFields({field("Ping",p.."ms",true),field("Threshold",Config.PingSpikeThreshold.."ms",true)}) }))
        end
    end)
end

local function setupTokenWatcher()
    local ok, label = pcall(function()
        return LP:WaitForChild("PlayerGui",10)
            :WaitForChild("TradeTokenCurrency_UI",10)
            :WaitForChild("TradeTokens",10)
            :WaitForChild("TextLabel1",10)
    end)
    if not ok or not label then logAdd("warn","token label not found"); return end
    local last = label.Text
    logAdd("ok","token watcher started — "..last)
    label:GetPropertyChangedSignal("Text"):Connect(function()
        local new = label.Text
        if new ~= last then
            local prev = last; last = new
            logAdd("info","tokens: "..prev.." → "..new)
            send(buildEmbed({ title="Tokens Updated", color=0xFEE75C,
                fields=commonFields({field("Before",prev,true),field("After",new,true)}) }))
        end
    end)
end

