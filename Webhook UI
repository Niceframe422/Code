    local stLbl = Instance.new("TextLabel")
    stLbl.Text             = ""
    stLbl.Size             = UDim2.new(1,0,0,12)
    stLbl.BackgroundTransparency = 1
    stLbl.TextColor3       = Theme.DIM
    stLbl.Font             = Enum.Font.Code
    stLbl.TextSize         = 9
    stLbl.TextXAlignment   = Enum.TextXAlignment.Left
    stLbl.LayoutOrder      = 4
    stLbl.Parent           = wrap

    saveBtn.MouseButton1Click:Connect(function()
        local url = inp.Text:gsub("%s+","")
        if url == "" then stLbl.Text = "empty"; stLbl.TextColor3 = Theme.RED; return end
        Config.Webhooks[routeKey] = url
        saveWebhooks()
        stLbl.Text       = "saved"
        stLbl.TextColor3 = Theme.GREEN
        logAdd("ok", "webhook saved: "..routeKey)
        if onSaved then onSaved(url) end
    end)

    -- "test" fires a real embed to this route right now so you can verify
    -- the URL is correct and the bot has permission to post in that channel.
    testBtn.MouseButton1Click:Connect(function()
        sendTo(routeKey, buildEmbed({
            title  = "Test — "..routeKey,
            color  = 0x5865F2,
            fields = commonFields({ field("Route", routeKey, true) })
        }))
        stLbl.Text       = "test sent"
        stLbl.TextColor3 = Theme.BLUE
    end)

    clearBtn.MouseButton1Click:Connect(function()
        inp.Text                  = ""
        Config.Webhooks[routeKey] = ""
        saveWebhooks()
        stLbl.Text       = "cleared"
        stLbl.TextColor3 = Theme.RED
        logAdd("warn", "webhook cleared: "..routeKey)
    end)

    return inp, stLbl
end

