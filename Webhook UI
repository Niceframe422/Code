            local col = p < 100 and Theme.GREEN or p < 200 and Theme.YELLOW or Theme.RED
            pingV.Text      = p.."ms";  pingV.TextColor3 = col
            pngCurV.Text    = p.."ms";  pngCurV.TextColor3 = col
