    local lastSpike = 0
    RunService.Heartbeat:Connect(function()
        if not Config.Modules.PingMonitor.enabled then return end
        if tick() - lastSpike < 60 then return end
        local p = getPing()
        if p >= Config.PingSpikeThreshold then
            lastSpike = tick()
            logAdd("warn", "ping spike: "..p.."ms")
            sendTo("alerts", buildEmbed({
                title  = "Ping Spike",
                color  = 0xFF4444,
                fields = commonFields({
                    field("Ping",      p.."ms",                         true),
                    field("Threshold", Config.PingSpikeThreshold.."ms", true),
                })
            }))
        end
    end)
end

--====================================================
-- TOKEN WATCHER
-- Watches: PlayerGui > TradeTokenCurrency_UI > TradeTokens > TextLabel1
--
-- What it does:
--   1. Polls every second until it finds TextLabel1 (up to 60s).
--      This handles cases where the trade UI loads after character spawn.
--   2. Reads the initial value and IMMEDIATELY sends it to Discord as
--      a "baseline" embed so you always know what the count was at startup,
--      even if no change happens during the session.
--   3. Connects GetPropertyChangedSignal("Text") so every subsequent change
--      fires an embed with before/after values and a +/- delta.
--   4. If the label is destroyed (trade UI closes and reopens), the watcher
--      restarts itself automatically.
--
-- TO WATCH A DIFFERENT LABEL:
--   Replace the three FindFirstChild calls in findLabel() with the correct
--   path for your label. Use the "probe path" button in the UI to explore
--   the tree and find the right names.
--
-- TO SEND TO A DIFFERENT CHANNEL:
--   Change webhookKey = "tokens" in Config.Modules.TokenWatcher to whatever
--   route key you want, then set that route's URL in the webhooks tab.
--====================================================
local function setupTokenWatcher()

    local function parseTokens(txt)
        if not txt then return nil end
        local cleaned = txt:gsub("[^%d%-]", "") -- only numbers
        return tonumber(cleaned)
    end

    local ui = Config._TokUI

    local function setStatus(msg, col)
        if ui and ui.status then
            ui.status.Text = msg
            ui.status.TextColor3 = col or Theme.MUTED
        end
    end

    local function updateBigDisplay(txt, delta)
        if not ui then return end
        ui.bigVal.Text = (txt ~= "" and txt or "0")
        ui.bigVal.TextColor3 =
            delta > 0 and Theme.GREEN or
            delta < 0 and Theme.RED or
            Theme.ORANGE
    end

    local sessionGain = 0
    local sessionLoss = 0
    local changeCount = 0

    local function updateSessionUI()
        if not ui then return end
        ui.totalGain.Text = "+"..sessionGain
        ui.totalLoss.Text = "−"..math.abs(sessionLoss)
        ui.changes.Text = tostring(changeCount)
    end

    -- ✅ FIXED LABEL FINDER (deep search)
    local function findLabel()
        local deadline = tick() + 60

        while tick() < deadline do
            local lbl = PG:FindFirstChild("TextLabel1", true)

            if lbl and lbl:IsA("TextLabel") then
                return lbl
            end

            task.wait(1)
        end

        return nil
    end

    task.spawn(function()
        setStatus("searching…", Theme.YELLOW)

        local label = findLabel()

        if not label then
            setStatus("not found", Theme.RED)
            warn("Token label not found")
            return
        end

        -- ✅ WAIT UNTIL TEXT IS VALID
        repeat
            task.wait()
        until label.Text and label.Text ~= ""

        local lastText = label.Text
        local lastNum = parseTokens(lastText)

        updateBigDisplay(lastText, 0)
        setStatus("active", Theme.GREEN)

        -- ✅ SEND INITIAL SNAPSHOT
        if Config.Modules.TokenWatcher.enabled then
            sendTo("tokens", buildEmbed({
                title = "Token Snapshot",
                color = 0xFFAA00,
                fields = commonFields({
                    field("Tokens", lastText ~= "" and lastText or "0", true),
                })
            }))
        end

        -- ✅ HANDLE UI BEING REPLACED
        label.AncestryChanged:Connect(function()
            if not label.Parent then
                setStatus("UI changed, reconnecting...", Theme.YELLOW)
                task.wait(1)
                setupTokenWatcher()
            end
        end)

        -- ✅ MAIN UPDATE FUNCTION (REUSABLE)
        local function processChange(newText)
            if newText == lastText then return end

            local prevText = lastText
            local prevNum = parseTokens(prevText)
            local newNum = parseTokens(newText)

            lastText = newText

            local delta = 0
            if newNum and prevNum then
                delta = newNum - prevNum
            end

            changeCount += 1

            if delta > 0 then
                sessionGain += delta
            elseif delta < 0 then
                sessionLoss += delta
            end

            updateBigDisplay(newText, delta)
            updateSessionUI()

            -- UI
            if ui then
                ui.lastChg.Text = timeStr()

                if delta ~= 0 then
                    local sign = delta > 0 and "+" or ""
                    ui.delta.Text = sign..delta
                    ui.delta.TextColor3 = delta > 0 and Theme.GREEN or Theme.RED

                    task.delay(3, function()
                        if ui.delta.Text == sign..delta then
                            ui.delta.Text = ""
                        end
                    end)
                end
            end

            -- DISCORD
            if Config.Modules.TokenWatcher.enabled then
                sendTo("tokens", buildEmbed({
                    title =
                        delta > 0 and "Tokens Gained" or
                        delta < 0 and "Tokens Lost" or
                        "Tokens Updated",

                    color =
                        delta > 0 and 0x44D264 or
                        delta < 0 and 0xED4245 or
                        0xFFAA00,

                    fields = commonFields({
                        field("Before", prevText, true),
                        field("After", newText ~= "" and newText or "0", true),
                        field("Change",
                            delta ~= 0 and ((delta > 0 and "+" or "")..delta) or "0",
                            true
                        ),
                        field("Session Gain", "+"..sessionGain, true),
                        field("Session Loss", "−"..math.abs(sessionLoss), true),
                        field("Changes", tostring(changeCount), true),
                    })
                }))
            end
        end

        -- ✅ EVENT LISTENER
        label:GetPropertyChangedSignal("Text"):Connect(function()
            processChange(label.Text)
        end)

        -- ✅ BACKUP LOOP (VERY IMPORTANT)
        task.spawn(function()
            while label and label.Parent do
                task.wait(1)

                local current = label.Text
                if current ~= lastText then
                    processChange(current)
                end
            end
        end)

    end)
end

