    --==============================================
    -- LIVE UPDATE LOOP
    --==============================================
    local startTick    = tick()
    local pingBuf      = {}
    local peakPing     = 0
    local lastPingTick = 0

    RunService.Heartbeat:Connect(function()
        local el = math.floor(tick() - startTick)
        uptimeV.Text = ("%02d:%02d:%02d"):format(
            math.floor(el/3600), math.floor((el%3600)/60), el%60)

        if tick() - lastPingTick >= 2 then
            lastPingTick = tick()
            local p   = getPing()
            table.insert(pingBuf, p)
            if #pingBuf > 150 then table.remove(pingBuf,1) end
            peakPing = math.max(peakPing, p)
            local sum = 0
            for _, v in ipairs(pingBuf) do sum = sum + v end
