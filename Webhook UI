local function setupPlayerEvents()
    local function onAdded(player)
        if not Config.Modules.PlayerEvents.enabled then return end
        local age = "unknown"
        local ok, a = pcall(function() return player:GetAccountAge() end)
        if ok then age = math.floor(a/365).."y "..math.floor((a%365)/30).."m" end
        logAdd("ok", player.Name.." joined (age: "..age..")")
        sendTo("players", buildEmbed({
            title  = "Player Joined",
            color  = Config.Modules.PlayerEvents.color,
            fields = commonFields({
                field("Player", player.Name, true),
                field("Age",    age,         true),
                field("UserId", player.UserId, true),
            })
        }))
    end

    local function onRemoving(player)
        if not Config.Modules.PlayerEvents.enabled then return end
        logAdd("err", player.Name.." left")
        sendTo("players", buildEmbed({
            title  = "Player Left",
            color  = 0xED4245,
            fields = commonFields({ field("Player", player.Name, true) })
        }))
    end

    Players.PlayerAdded:Connect(onAdded)
    Players.PlayerRemoving:Connect(onRemoving)
    for _, p in ipairs(Players:GetPlayers()) do task.spawn(onAdded, p) end
end

local function setupDisconnect()
    game:BindToClose(function()
        if not Config.Modules.Disconnect.enabled then return end
        logAdd("err","session ended / disconnect")
        sendTo("alerts", buildEmbed({
            title  = "Session Ended",
            color  = 0xFEE75C,
            fields = commonFields({ field("Player", LP.Name, true) })
        }))
    end)
end

local function setupPingMonitor()
    local lastSpike = 0
    RunService.Heartbeat:Connect(function()
        if not Config.Modules.PingMonitor.enabled then return end
        if tick() - lastSpike < 60 then return end
        local p = getPing()
        if p >= Config.PingSpikeThreshold then
            lastSpike = tick()
            logAdd("warn","ping spike: "..p.."ms")
            sendTo("alerts", buildEmbed({
                title  = "Ping Spike",
                color  = 0xFF4444,
                fields = commonFields({
                    field("Ping",      p.."ms",                         true),
                    field("Threshold", Config.PingSpikeThreshold.."ms", true),
                })
            }))
        end
    end)
end

local function setupTokenWatcher()
    -- helper: strip commas and parse as number (handles "1,234" style values)
    local function parseTokens(txt)
        if not txt or txt == "" then return nil end
        local clean = txt:gsub(",", ""):gsub("%s+", "")
        return tonumber(clean)
    end

    local ui = Config._TokUI  -- reference to live GUI labels built in createPanel()

    local function setStatus(msg, col)
        if ui and ui.status then
            ui.status.Text      = msg
            ui.status.TextColor3= col or Theme.MUTED
        end
    end

    -- session accumulators
    local sessionGain   = 0
    local sessionLoss   = 0
    local changeCount   = 0

    local function updateSessionUI()
        if not ui then return end
        ui.totalGain.Text       = "+"..tostring(sessionGain)
        ui.totalGain.TextColor3 = sessionGain > 0 and Theme.GREEN or Theme.MUTED
        ui.totalLoss.Text       = "−"..tostring(math.abs(sessionLoss))
        ui.totalLoss.TextColor3 = sessionLoss < 0 and Theme.RED or Theme.MUTED
        ui.changes.Text         = tostring(changeCount)
    end

    -- try to locate the label, retrying if the ScreenGui hasn't loaded yet
    local function findLabel()
        -- TradeTokenCurrency_UI can appear after character load; poll up to 60s
        local deadline = tick() + 60
        while tick() < deadline do
            local sg  = PG:FindFirstChild("TradeTokenCurrency_UI")
            if sg then
                local tt  = sg:FindFirstChild("TradeTokens")
                if tt then
                    local lbl = tt:FindFirstChild("TextLabel1")
                    if lbl then return lbl end
                end
            end
            task.wait(1)
        end
        return nil
    end

    task.spawn(function()
        setStatus("searching…", Theme.YELLOW)
        logAdd("info", "token watcher: searching for TradeTokenCurrency_UI…")

        local label = findLabel()

        if not label then
            setStatus("label not found", Theme.RED)
            logAdd("warn", "token watcher: TextLabel1 not found after 60s")
            return
        end

        -- initial read
        local lastText = label.Text
        local lastNum  = parseTokens(lastText)

        -- update big display
        if ui then
            ui.bigVal.Text = lastText ~= "" and lastText or "0"
            ui.lastChg.Text = "just now"
        end
        setStatus("active", Theme.GREEN)
        logAdd("ok", "token watcher started — current: "..(lastText ~= "" and lastText or "0"))

        -- also watch if the label's parent gets destroyed (trade UI closed/reopened)
        label.AncestryChanged:Connect(function()
            if not label.Parent then
                setStatus("label removed, retrying…", Theme.YELLOW)
                logAdd("warn","token label removed — re-searching")
                task.spawn(setupTokenWatcher)   -- restart the watcher
            end
        end)

        label:GetPropertyChangedSignal("Text"):Connect(function()
            local newText = label.Text
            if newText == lastText then return end

            local newNum  = parseTokens(newText)
            local prevNum = parseTokens(lastText)
            local prevTxt = lastText
            lastText = newText

            -- compute delta
            local delta = 0
            if newNum and prevNum then
                delta = newNum - prevNum
            end

            -- accumulate session stats
            changeCount = changeCount + 1
            if delta > 0 then
                sessionGain = sessionGain + delta
            elseif delta < 0 then
                sessionLoss = sessionLoss + delta
            end

            -- update big display
            if ui then
                ui.bigVal.Text = newText ~= "" and newText or "0"
                ui.bigVal.TextColor3 = delta > 0 and Theme.GREEN
                                    or delta < 0 and Theme.RED
                                    or Theme.ORANGE

                -- delta badge: fade back to nothing after 4s
                if delta ~= 0 then
                    local sign = delta > 0 and "+" or ""
                    ui.delta.Text       = sign..tostring(delta)
                    ui.delta.TextColor3 = delta > 0 and Theme.GREEN or Theme.RED
                    task.delay(4, function()
                        if ui.delta.Text == sign..tostring(delta) then
                            ui.delta.Text = ""
                            ui.bigVal.TextColor3 = Theme.ORANGE
                        end
                    end)
                end

                ui.lastChg.Text = timeStr()
                ui.lastChg.TextColor3 = Theme.TEXT
                updateSessionUI()

                -- add history row
                ui.addRow(prevTxt ~= "" and prevTxt or "?", newText, delta)
            end

            -- log
            local sign = delta > 0 and "+" or ""
            logAdd(delta >= 0 and "ok" or "warn",
                "tokens: "..prevTxt.." → "..newText..(delta ~= 0 and " ("..sign..delta..")" or ""))

            -- webhook embed (respects module toggle)
            if Config.Modules.TokenWatcher.enabled then
                local embedCol = delta > 0 and 0x44D264 or delta < 0 and 0xED4245 or 0xFFAA00
                local deltaStr = delta ~= 0 and ((delta > 0 and "+" or "")..tostring(delta)) or "no change"
                sendTo("tokens", buildEmbed({
                    title       = delta > 0 and "Tokens Gained" or delta < 0 and "Tokens Lost" or "Tokens Changed",
                    color       = embedCol,
                    description = delta > 0
                        and "Gained **"..tostring(delta).."** tokens"
                        or  delta < 0
                        and "Lost **"..tostring(math.abs(delta)).."** tokens"
                        or  "Token count refreshed",
                    fields = commonFields({
                        field("Before",       prevTxt,            true),
                        field("After",        newText,            true),
                        field("Change",       deltaStr,           true),
                        field("Session Gain", "+"..tostring(sessionGain),  true),
                        field("Session Loss", "−"..tostring(math.abs(sessionLoss)), true),
                        field("# Changes",    tostring(changeCount),       true),
                    })
                }))
            end
        end)
    end)
end

