--====================================================
-- FILE HELPERS (safe for all executors)
--====================================================
local function fileSave(path, text)
    local ok, err = pcall(writefile, path, text)
    if not ok then warn("[Monitor] writefile failed:", err) end
    return ok
end

local function fileLoad(path)
    local ok, v = pcall(readfile, path)
    return (ok and type(v) == "string" and #v > 0) and v or nil
end

local function fileExists(path)
    -- isfile() is safer than readfile for existence check
    if isfolder ~= nil then
        -- not relevant but guard
    end
    if isfile then
        local ok, v = pcall(isfile, path)
        if ok then return v end
    end
    local ok, v = pcall(readfile, path)
    return ok and type(v) == "string" and #v > 0
end

local function fileDel(path)
    if delfile then pcall(delfile, path) end
end

--====================================================
-- UTILITIES
--====================================================
local function utcNow()
    local t = os.date("!*t", os.time())
    return ("%d-%02d-%02dT%02d:%02d:%02dZ"):format(
        t.year, t.month, t.day, t.hour, t.min, t.sec)
end

local function timeStr()
    local t = os.date("!*t", os.time())
    return ("%02d:%02d:%02d"):format(t.hour, t.min, t.sec)
end

local function getPing()
    local ok, p = pcall(function()
        return math.round(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
    end)
    return ok and p or 0
end

local function getPlayerCount() return #Players:GetPlayers() end

local function getGameName()
    local ok, info = pcall(function()
        return game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId)
    end)
    return (ok and info and info.Name) and info.Name or tostring(game.PlaceId)
end

local function getRequest()
    return (syn and syn.request)
        or (http and http.request)
        or (fluxus and fluxus.request)
        or http_request
        or request
end

--====================================================
-- LOG BUFFER
--====================================================
local LogBuffer   = {}
local LogCBs      = {}

local function logAdd(kind, msg)
    local e = { kind = kind, msg = msg, ts = timeStr() }
    table.insert(LogBuffer, 1, e)
    if #LogBuffer > 60 then table.remove(LogBuffer) end
    for _, cb in ipairs(LogCBs) do pcall(cb, e) end
end

local function onLog(cb) table.insert(LogCBs, cb) end

--====================================================
-- WEBHOOK SEND
--====================================================
local WEBHOOK_URL = nil

local function field(n, v, i) return { name = n, value = tostring(v), inline = i == true } end

local function commonFields(extra)
    local f = {}
    if Config.Send.IncludeGameName    then table.insert(f, field("Game",    getGameName(),    true)) end
    if Config.Send.IncludePlayerCount then table.insert(f, field("Players", getPlayerCount(), true)) end
    if Config.Send.IncludePing        then table.insert(f, field("Ping",    getPing().."ms",  true)) end
    table.insert(f, field("Time", timeStr(), false))
    for _, v in ipairs(extra or {}) do table.insert(f, v) end
    return f
end

local function buildEmbed(opts)
    local e = { title = opts.title or "", color = opts.color or 0x5865F2, fields = opts.fields or {} }
    if Config.Send.IncludeTimestamp then e.timestamp = utcNow() end
    return e
end

local embedsSent = 0
local function send(embed)
    if not WEBHOOK_URL or WEBHOOK_URL == "" then return end
    local req = getRequest()
    if not req then warn("[Monitor] No http request function found") return end
    local ok, err = pcall(function()
        req({
            Url     = WEBHOOK_URL,
            Method  = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body    = HttpService:JSONEncode({
                username = Config.Username,
                embeds   = { embed }
            })
        })
    end)
    if ok then
        embedsSent = embedsSent + 1
        logAdd("info", "embed sent — " .. (embed.title or "?"))
    else
        logAdd("err", "send failed: " .. tostring(err))
    end
end

