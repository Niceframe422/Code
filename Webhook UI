    inp.PlaceholderColor3= Theme.DIM
    inp.Font             = Enum.Font.Code
    inp.TextSize         = 10
    inp.ClearTextOnFocus = false
    inp.BorderSizePixel  = 0
    inp.LayoutOrder      = 2
    inp.Parent           = wrap
    mkCorner(inp, 6)

    -- button row
    local bRow = Instance.new("Frame")
    bRow.Size             = UDim2.new(1,0,0,24)
    bRow.BackgroundTransparency = 1
    bRow.BorderSizePixel  = 0
    bRow.LayoutOrder      = 3
    bRow.Parent           = wrap

