    mkInfo(threshCt, "rejoin delay",    Config.RejoinDelay.."s",          3, Theme.MUTED)

    --==============================================
    -- LOG PAGE
    --==============================================
    local logPage = pages["log"]

    local logCt = mkSection(logPage, "activity log", Theme.BLUE, 1)

    local logScroll = Instance.new("ScrollingFrame")
    logScroll.Size                 = UDim2.new(1,0,0,220)
    logScroll.BackgroundColor3     = Theme.BG3
    logScroll.BorderSizePixel      = 0
    logScroll.ScrollBarThickness   = 3
    logScroll.ScrollBarImageColor3 = Theme.BORDER
    logScroll.CanvasSize           = UDim2.new(0,0,0,0)
    logScroll.AutomaticCanvasSize  = Enum.AutomaticSize.Y
    logScroll.LayoutOrder          = 1
    logScroll.Parent               = logCt
    mkCorner(logScroll, 6)

    local logLL = Instance.new("UIListLayout", logScroll)
    logLL.Padding   = UDim.new(0,0)
    logLL.SortOrder = Enum.SortOrder.LayoutOrder

    local logPad = Instance.new("UIPadding", logScroll)
    logPad.PaddingLeft   = UDim.new(0,6)
    logPad.PaddingRight  = UDim.new(0,6)
    logPad.PaddingTop    = UDim.new(0,4)
    logPad.PaddingBottom = UDim.new(0,4)

    local logRowOrder = 0
    local function addLogRow(entry)
        logRowOrder = logRowOrder + 1
        local tc = (entry.kind=="ok")   and Theme.GREEN
                or (entry.kind=="err")  and Theme.RED
                or (entry.kind=="warn") and Theme.YELLOW
                or Theme.BLUE

        local row = Instance.new("Frame")
        row.Size             = UDim2.new(1,0,0,16)
        row.BackgroundTransparency = 1
        row.BorderSizePixel  = 0
        row.LayoutOrder      = logRowOrder
        row.Parent           = logScroll

        local ts = Instance.new("TextLabel")
        ts.Text            = entry.ts
        ts.Size            = UDim2.new(0,65,1,0)
        ts.BackgroundTransparency = 1
        ts.TextColor3      = Theme.DIM
        ts.Font            = Enum.Font.Code
        ts.TextSize        = 10
        ts.TextXAlignment  = Enum.TextXAlignment.Left
        ts.Parent          = row

        local msg = Instance.new("TextLabel")
        msg.Text           = entry.msg
        msg.Size           = UDim2.new(1,-67,1,0)
        msg.Position       = UDim2.new(0,67,0,0)
        msg.BackgroundTransparency = 1
        msg.TextColor3     = tc
        msg.Font           = Enum.Font.Code
        msg.TextSize       = 10
        msg.TextXAlignment = Enum.TextXAlignment.Left
        msg.TextTruncate   = Enum.TextTruncate.AtEnd
        msg.Parent         = row

        task.defer(function()
            logScroll.CanvasPosition = Vector2.new(0, math.huge)
        end)
    end

    for i = #LogBuffer, 1, -1 do addLogRow(LogBuffer[i]) end
    onLog(addLogRow)

    --==============================================
    -- LIVE UPDATE LOOP
    --==============================================
    local startTick    = tick()
    local pingBuf      = {}
    local peakPing     = 0
    local lastPingTick = 0

    RunService.Heartbeat:Connect(function()
        local el = math.floor(tick() - startTick)
        uptimeV.Text = ("%02d:%02d:%02d"):format(
            math.floor(el/3600), math.floor((el%3600)/60), el%60)

        if tick() - lastPingTick >= 2 then
            lastPingTick = tick()
            local p = getPing()
            table.insert(pingBuf, p)
            if #pingBuf > 150 then table.remove(pingBuf,1) end
            peakPing = math.max(peakPing, p)
            local sum = 0
            for _, v in ipairs(pingBuf) do sum = sum + v end
            local avg = math.round(sum / #pingBuf)

            local pingCol = p < 100 and Theme.GREEN or p < 200 and Theme.YELLOW or Theme.RED
            pingV.Text      = p.."ms";  pingV.TextColor3 = pingCol
            pngCurV.Text    = p.."ms";  pngCurV.TextColor3 = pingCol
            pngAvgV.Text    = avg.."ms"
            pngPeakV.Text   = peakPing.."ms";
            pngPeakV.TextColor3 = peakPing > 200 and Theme.RED or Theme.TEXT

            playersV.Text   = getPlayerCount().." / "..Players.MaxPlayers
        end

        sentV.Text   = tostring(embedsSent)
        errV.Text    = tostring(sendErrors);  errV.TextColor3 = sendErrors > 0 and Theme.RED or Theme.MUTED
        logCntV.Text = tostring(#LogBuffer)

        -- refresh webhook status in monitor tab
        for key, lbl in pairs(whStatRow) do
            local has = Config.Webhooks[key] and Config.Webhooks[key] ~= ""
            lbl.Text       = has and "configured" or "not set"
            lbl.TextColor3 = has and Theme.GREEN or Theme.RED
        end
    end)

    task.spawn(function() gameV.Text = getGameName() end)

    --// AFK DETECTION
    local lastInput = tick()
    local isAFK     = false

    UserInputService.InputBegan:Connect(function()
        lastInput = tick()
        afkLastV.Text = "0s"
        if isAFK then
            isAFK = false
            afkStatV.Text       = "active"
            afkStatV.TextColor3 = Theme.GREEN
            logAdd("ok","returned from afk")
            if Config.Modules.AFK.enabled then
                sendTo("default", buildEmbed({ title="Returned from AFK", color=0x57F287,
                    fields=commonFields({field("Player", LP.Name, true)}) }))
            end
        end
    end)

    RunService.Heartbeat:Connect(function()
        local idle = math.floor(tick() - lastInput)
        afkLastV.Text = idle.."s"
        if not isAFK and idle >= Config.AFKThreshold then
            isAFK = true
            afkStatV.Text       = "afk"
            afkStatV.TextColor3 = Theme.YELLOW
            logAdd("warn","went afk ("..idle.."s)")
            if Config.Modules.AFK.enabled then
                sendTo("default", buildEmbed({ title="Player AFK", color=0xFEE75C,
                    fields=commonFields({
                        field("Player", LP.Name,                    true),
                        field("Idle",   Config.AFKThreshold.."s",   true)
                    })
                }))
            end
        end
    end)
end

